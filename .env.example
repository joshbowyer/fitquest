# Database (used by api container; matches docker-compose.yml postgres service)
DATABASE_URL=postgresql://fitness:fitness@postgres:5432/fitquest

# API
NODE_ENV=production
PORT=3001
API_HOST=0.0.0.0
# IMPORTANT: generate a long random string for production. Anything
# shorter than 32 chars will cause the cookie layer to refuse to start.
# Example: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string-min-32-chars
# Browser origin for CORS. In docker setup behind nginx (port 8080),
# this is http://localhost:8080. Behind Caddy (production profile),
# use https://your-domain.tld.
WEB_ORIGIN=http://localhost:8080

# API_COOKIE_DOMAIN: REQUIRED in any non-localhost deployment where
# the api vhost and the web vhost are sibling subdomains of the
# same parent (e.g. api.example.com and www.example.com). Set to
# the leading-dot parent so BOTH session and trusted-device
# cookies are scoped to the parent domain and sent on requests
# to either vhost. Leave unset for localhost-only dev (the cookie
# layer falls back to host-only, which is correct for one host).
# Example for api.example.com + www.example.com: API_COOKIE_DOMAIN=.example.com
# API_COOKIE_DOMAIN=.example.com

# Production (Caddy profile only) — your public hostname. Caddy
# auto-provisions a Let's Encrypt cert for this domain.
# WEB_DOMAIN=fit.example.com

# Web: VITE_API_URL is intentionally not set by default. The web's
# lib/api.ts falls back to '/api', and the web's nginx proxies
# /api/* → api:3001. Set this only if you want the browser to hit
# the API directly (separate origins) at build time.
# VITE_API_URL=http://localhost:3001

# WEB_ORIGIN_EXTRA: comma-separated list of additional allowed
# CORS origins. Required when the api domain differs from the
# web domain (e.g. api.fitquest.app vs fitquest.app) so the
# Capacitor WebView (which loads at https://localhost) can
# call the api. Default 'https://localhost' so the APK works
# out of the box for any same-LAN / same-host setup. If the
# user enters a custom domain in the first-run prompt, you
# can either add that domain to WEB_ORIGIN_EXTRA or override
# the runtime apiBaseUrl to point at an origin already in the
# list.
WEB_ORIGIN_EXTRA=https://localhost
