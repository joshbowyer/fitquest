generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClassName {
  JUGGERNAUT
  PHANTOM
  SCOUT
  BERSERKER
  TRACER
  ORACLE
}

/// Possible triggers that cost a Hardcore-mode heart. One enum
/// value per row written to HeartLossEvent.kind.
enum HeartLossTrigger {
  /// Yesterday was a planned workout day in the routine and no
  /// workout landed in that window.
  MISSED_WORKOUT
  /// Every expected daily (including the user's configured spiritual
  /// prayers) was skipped yesterday.
  MISSED_ALL_DAILIES
  /// Yesterday's caffeine log count exceeded HARDCORE_SUBSTANCE_CAPS.
  SUBSTANCE_CAFFEINE
  /// Rolling 7-day alcohol count exceeded HARDCORE_SUBSTANCE_CAPS.
  SUBSTANCE_ALCOHOL
  /// Rolling 7-day nicotine count exceeded HARDCORE_SUBSTANCE_CAPS.
  SUBSTANCE_NICOTINE
  /// No spiritual activity logged yesterday (any prayer type,
  /// mass, scripture reading, etc.) — independent of dailies so
  /// users without configured spiritual dailies still get credit
  /// for engaging in any spiritual practice.
  ZERO_SPIRITUAL
}

enum MetricType {
  // Hypertrophy (circumferences in cm).
  // BICEP was a single combined metric until 20260706; it split
  // into BICEP_FLEXED (peak contraction, "show off" measurement,
  // the canonical Casey Butt formula target) and BICEP_RELAXED
  // (arm hanging at side, ~1.5-2cm smaller, useful for tracking
  // arm size without pump effects). Existing BICEP rows were
  // migrated to BICEP_FLEXED by the migration — convention is to
  // measure flexed unless stated otherwise. BICEP itself remains
  // in the enum as a legacy alias (Postgres can't drop enum
  // values without recreating the type) but no client emits it.
  BICEP
  BICEP_FLEXED
  BICEP_RELAXED
  CHEST
  // SHOULDER is the shoulder-to-shoulder BREADTH (not circumference)
  SHOULDER
  QUAD
  CALF
  FOREARM
  NECK
  WAIST
  // Strength (1RM in kg)
  BENCH_1RM
  SQUAT_1RM
  DEADLIFT_1RM
  OHP_1RM
  PULLUP_1RM
  // Body composition (LEAN_MASS, FFMI are derived — see User)
  BODY_FAT_PCT
  LEAN_MASS
  FFMI
  WEIGHT
  // Cardio / endurance (times in seconds)
  VO2_MAX
  RESTING_HR
  HRV
  FIVE_K_TIME
  ONE_MILE_TIME
  // Calisthenics
  PLANK_HOLD
  L_SIT_HOLD
  DEAD_HANG
  // Max-reps calisthenics (single-set max)
  PUSHUP_MAX
  PULLUP_MAX
  // Powerlifts (composite)
  POWERLIFT_TOTAL
  // Sleep
  SLEEP_HOURS
  SLEEP_QUALITY
  // Nutrition
  CALORIES
  PROTEIN_G
  WATER_ML
  // Wellness (1-10 subjective scales)
  MOOD
  ENERGY
  SORENESS
  STRESS
  // Garmin HSA / METRICS file imports
  // BODY_BATTERY: 0-100, 5 min sample. Higher = more recovered.
  // STEPS: total daily step count.
  BODY_BATTERY
  STEPS
  // RESPIRATION_RATE: breaths per minute (from MONITOR file
  // RespirationRateMesg). Emitted by parseMonitor in api/src/lib/fit.ts
  // but missing from this enum would 500 every MONITOR file with
  // respiration data on import. Critical fix.
  RESPIRATION_RATE
  /// Hour-of-day the user fell asleep the previous night, stored
  /// as fractional hours (22.5 = 10:30 PM). Computed from
  /// parseSleep + localNightStart so a 12:30 AM sleep bucketed to
  /// the previous calendar day.
  /// Migration: 20250707190000_add_sleep_onset.
  SLEEP_ONSET
}

enum MetricCategory {
  HYPERTROPHY
  STRENGTH
  BODY_COMP
  CARDIO
  CALISTHENICS
}

enum WorkoutType {
  STRENGTH
  HYPERTROPHY
  CALISTHENICS
  CARDIO
  MOBILITY
  OTHER
}

/// Which surface ingested the workout. Lets the /import page
/// distinguish bridge uploads from web drags, and keeps the
/// door open for bulk-reprocess imports later without another
/// enum migration. Default WEB — every existing row + every
/// non-bridge future ingest keeps the legacy behaviour.
enum WorkoutSource {
  WEB
  BRIDGE
  BULK_REPROCESS
}

/// Method used to record a body-fat or weight measurement.
/// Methodologically-known (DEXA / BOD_POD / NAVY_TAPE) get full
/// confidence in the morning report's body-comp insight; visual
/// estimates get partial; MANUAL + UNKNOWN are treated as low
/// confidence. Kept in sync with the DB-side enum (see migration
/// 20250707170000_add_measurement_source).
enum MeasurementSource {
  DEXA
  BOD_POD
  NAVY_TAPE
  CALIPERS
  BIA
  VISUAL
  UNKNOWN
  MANUAL
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum HairStyle {
  SHORT
  LONG
  MOHAWK
  BUZZ
  PONYTAIL
  PIXIE
}

enum PrType {
  ONE_RM
  VOLUME
  REPS
  TIME
  HOLD
}

enum CalorieGoal {
  CUT
  MAINTAIN
  BULK
}

/// What the user's calorieBaseline actually represents. Drives how
/// the morning report + Nutrition page label the number. The
/// calculation logic is the same — only the label changes.
///
/// - BASELINE:    typical TDEE estimate (the default). User knows their
///                 maintenance from real-world weight-stable data.
/// - BMR:         basal metabolic rate only (Mifflin-St Jeor or similar).
///                 User is saying "I'm sedentary; do the rest from there."
/// - BMR_NEAT:    BMR + non-exercise activity thermogenesis. User has
///                 accounted for daily movement but NOT for workouts.
enum CalorieSource {
  BASELINE
  BMR
  BMR_NEAT
}

enum SkillTier {
  TIER_1
  TIER_2
  TIER_3
  // T4 / T5 / T6 are reserved for per-branch "god-tier" skills
  // that are clearly harder than the rest of the T3 set in the
  // same branch (e.g. PHANTOM Holds' 30s V-Sit / 5s Back Lever,
  // JUGGERNAUT Strongman's 200ft Atlas carry, BERSERKER Sandbag's
  // 30-rep god-tier set). Per-branch maxTier lives in the seed
  // SPEC.maxTier field, defaulting to TIER_3 if not specified.
  // The SkillTree page uses `s.tier === branch.maxTier` to
  // decide which nodes get the god-tier glow treatment.
  TIER_4
  TIER_5
  TIER_6
}

/// Difficulty / penalty mode. Casual is the legacy no-consequences
/// behavior; Hardcore engages the heart system, streak-break penalty,
/// and substance over-use caps. Users toggle in /settings.
enum UserMode {
  CASUAL
  HARDCORE
}

/// AI Coach personality preset. Drives the SYSTEM_PROMPT chosen
/// for /coach/* requests. The actual per-personality prompts live
/// in `api/src/lib/coach.ts` (code, not DB) so they can be tuned
/// without a migration; the enum is just the selector.
///
/// Personality roadmap: priest bodybuilder / Bob Ross / drill
/// sergeant / minmaxxer zoomer / generic polite. Generic is the
/// default — neutral AI-health-assistant tone that new users get
/// until they pick one.
enum CoachPersonality {
  /// Catholic/monastic imagery + hypertrophy talk. The default
  /// "FitQuest" voice. Reads like a parish priest who also deadlifts.
  PRIEST_BODYBUILDER
  /// Extremely soft, affirming, never negative. Bob Ross / Mr.
  /// Rogers gentle. "We'll just add a little happy little set here."
  BOB_ROSS
  /// Direct, focused, no-fluff drill sergeant. Not gratuitously
  /// foul-mouthed — discipline, not toxic.
  DRILL_SERGEANT
  /// Gym-bro subculture, "we pump", aesthetic, meme-fluent.
  /// Minmaxxer zoomer / Zyzz-bro energy.
  ZOOMER
  /// Generic polite AI personal-health-assistant. Safe default;
  /// used when no personality is selected yet.
  GENERIC
}

enum AchievementCategory {
  STRENGTH
  HYPERTROPHY
  CONSISTENCY
  ENDURANCE
  SOCIAL
  CALISTHENICS
  BODY_COMP
}

enum GeneticMaxSource {
  FORMULA
  MANUAL
  PROJECTED
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum RaidStatus {
  ACTIVE
  VICTORY
  DEFEAT
}

enum MemberRole {
  LEADER
  OFFICER
  MEMBER
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  username               String                  @unique
  /// Case-folded copy of `username` for case-insensitive login +
  /// unique-by-case uniqueness. Login routes look up by this
  /// column. `username` is preserved as the display name (whatever
  /// case the user typed at registration).
  usernameLower          String                  @unique
  passwordHash           String
  class                  ClassName?
  level                  Int                     @default(1)
  xp                     Int                     @default(0)
  gold                   Int                     @default(0)
  // Soulstones: world-boss drops with 24h TTL. Used to bypass the
  // class-change cooldown (respec). Each Soulstone row in the
  // Soulstone table is one consumable. The Int counter that used
  // to live here was dropped in migration 20260701120000 in favor
  // of the row-based model so we can track per-stone TTLs.
  units                  UnitSystem              @default(METRIC)
  // Static frame inputs (rarely change). Used by genetic-max formulas.
  heightCm               Float?
  wristCm                Float?
  ankleCm                Float?
  forearmLengthCm        Float?
  neckCircCm             Float?
  // Static frame measurements (don't change). Used by the Tron
  // identity disk to scale the disc radius, inner ring, and figure
  // position. Optional so existing users aren't blocked; the avatar
  // falls back to archetype-only scaling when missing.
  shoulderCm             Float?
  waistCm                Float?
  /// Home location for the /forecast page. Null = auto-fall back
  /// to the most-recent workout's track centroid until the user
  /// explicitly opts in via Profile.
  latitude               Float?
  longitude              Float?
  // Dynamic body metrics (change over time). Used by formulas + tracked.
  weightKg               Float?
  bodyFatPct             Float?
  birthDate              DateTime?
  // Cached PRs (kg or seconds depending on exercise)
  benchPr                Float?
  squatPr                Float?
  deadliftPr             Float?
  ohpPr                  Float?
  pullupPr               Int?
  // Relations
  sessions               Session[]
  measurements           Measurement[]
  geneticMaxes           GeneticMax[]
  workouts               Workout[]
  prs                    Pr[]
  partyMember            PartyMember?
  raidContribs           RaidContribution[]
  achievements           UserAchievement[]
  skills                 UserSkill[]
  homeBase               HomeBase?
  workoutTemplates       WorkoutTemplate[]
  penanceTemplates       PenanceTemplate[]
  penanceEvents          PenanceEvent[]
  heartLossEvents        HeartLossEvent[]
  /// Skill unlocks waiting for user confirmation. Created when a
  /// recent workout's set satisfies a locked skill's test. The
  /// SkillTree page shows these one at a time on mount.
  pendingSkillUnlocks    PendingSkillUnlock[]
  purchases              Purchase[]
  soulstones             Soulstone[]
  /// Adopted pet. One per user for v1 (single starter). v2 will
  /// Adopted pets. One user can own multiple pets (up to
  /// MAX_PETS_PER_USER=6 enforced at the API level). Earlier v1
  /// had `pet PetInstance?` (one-to-one) when the schema enforced
  /// @unique on PetInstance.userId; that constraint is now dropped
  /// for multi-pet support, so the relation here is one-to-many.
  pets                  PetInstance[]
  // Breach boss progress. One row per user; lazily created on
  // first /breach GET after level 10 OR first workout-commit
  // while unlocked (whichever happens first). Defined as ? here
  // so existing users without a row still load cleanly.
  userBreachProgress     UserBreachProgress?
  /// Per-workout Breach damage audit trail. Looked up by user
  /// (newest first) for the /breach damage feed. Cascades with
  /// the user row so account deletion stays clean.
  breachDamageEvents     BreachDamageEvent[]
  avatar                 Avatar?
  classChangedAt         DateTime?
  // Admin role. First user to register is bootstrapped to admin.
  // Future: 2FA / TOTP secret + recovery codes live here too.
  isAdmin                Boolean                 @default(false)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean                 @default(false)
  // TOTP recovery codes (one-time use, hashed at rest).
  twoFactorBackupCodes   String?
  worldProgress          UserWorldProgress[]
  painLogs               PainLog[]
  routine                Routine?
  worldBosses            WorldBoss[]
  sentInvites            PartyInvite[]           @relation("Inviter")
  receivedInvites        PartyInvite[]           @relation("Invitee")
  prayerLogs             PrayerLog[]
   habits                 Habit[]
   habitLogs              HabitLog[]
   todos                  TodoItem[]
   notifications          Notification[]
  supplements            SupplementLog[]
  routineDays            RoutineDay[]
  dailies                Daily[]
  dailyLogs              DailyLog[]
  inventoryItems         InventoryItem[]
  morningReports         MorningReport[]
  spiritualReflections   SpiritualReflection[]
  activityInsights       ActivityInsight[]
  metricInsights         MetricInsight[]
  plateauPauses          PlateauPause[]
  plateauSnapshots       PlateauSnapshot[]
  examenResponses        ExamenResponse[]
  trackedItems           UserTrackedItem[]
  dailyTracked           DailyTrackedItem[]
  substanceLogs          SubstanceLog[]
  mealEntries            MealEntry[]
  savedFoods             SavedFood[]
  correlationSnapshots   CorrelationSnapshot[]
  teamWorkoutsLed        TeamWorkout[]           @relation("TeamWorkoutLeader")
  teamParticipations     TeamParticipant[]
  trustedDevices         TrustedDevice[]
  recoveryCodes          RecoveryCode[]
  /// Single rolling coach conversation per user (auto-spawned on
  /// first /coach POST). Renaming / multi-conversation support is
  /// a future item — for now `userId @unique` enforces "one chat
  /// per user". Reset by DELETE /coach/messages. Messages are
  /// reached through CoachConversation.messages.
  coachConversation      CoachConversation?
  // Prayer types the user commits to perform daily. Drives the
  // built-in SPIRITUAL dailies shown on the /today page.
  spiritualDailyPrayers  PrayerType[]            @default([ROSARY, SCRIPTURE])
  // Creatine adds intracellular water weight (~1-2 kg). When true, the
  // user wants it accounted for in lean-mass display so a "real" LBM
  // number doesn't include the water. Stored raw so we can compute
  // both numbers downstream.
  creatine               Boolean                 @default(false)
  // IANA timezone name (e.g. "America/New_York"). Used to render
  // absolute timestamps in the user's local time. Defaults to UTC.
  timezone               String?
  spiritualSubclass      SpiritualSubclass?
  spiritualXp            Int                     @default(0)
  ordained               Boolean                 @default(false)
  ordainedAt             DateTime?
  sex                    Sex?
  /// Goal for daily calorie/macro targets. Drives the conservative
  /// ±250 cal adjustment from the user's calorie baseline, and
  /// shifts the protein target up (cut/maint) or down (bulk)
  /// per the user's preference for the high end of the range.
  /// Default MAINTAIN. User can override individual targets in
  /// /settings to fine-tune.
  goal                   CalorieGoal             @default(MAINTAIN)
  /// Casual/Hardcore difficulty toggle. Casual = current no-consequences
  /// behavior (streaks can be broken freely, no heart system). Hardcore =
  /// full penalty ladder (heart system, streak-break on miss, reduced XP
  /// when hearts are low). Default Casual so existing users aren't
  /// surprised by a difficulty change.
  mode                   UserMode                @default(CASUAL)
  /// AI Coach personality preset. Drives the SYSTEM_PROMPT for
  /// /coach/* requests — see api/src/lib/coach.ts for the actual
  /// per-personality prompts. Null = "show the picker, default to
  /// GENERIC after first selection". Per-user (not admin-controlled);
  /// the admin can later override the actual prompt text via
  /// `LlmConfig.coachSystemPromptOverrides` (roadmap item) but
  /// for now the system-default prompts in coach.ts are used.
  coachPersonality       CoachPersonality?
  /// Hearts (Hardcore mode only). 5 = full, 0 = -50% XP. Lose 1 per
  /// missed planned workout in the routine, regen 1 per 8h. Always 5
  /// in Casual mode (the value is preserved but unused).
  hearts                 Int                     @default(10)
  /// Timestamp of last heart regeneration tick. Used to compute
  /// accrued regeneration since last read; the server applies the
  /// accrued delta on every /users/me read so the UI stays honest
  /// about regen even if the user is offline for days.
  heartsLastRegenAt      DateTime?
  /// User-set baseline (TDEE-ish). The actual calorie target is
  /// this + goal offset (cut -250, maintain 0, bulk +250). Default
  /// 2200 is a reasonable placeholder; the user should set this to
  /// their actual maintenance once they have data.
  calorieBaseline        Int                     @default(2200)
  /// What the baseline number represents. Affects only the UI label
  /// ("Maintenance" vs "BMR" vs "BMR + NEAT"). Math is the same.
  calorieSource          CalorieSource           @default(BASELINE)
  /// USDA FoodData Central API key. Free; sign up at
  /// https://fdc.nal.usda.gov/api-key-signup.html. Required for the
  /// upcoming food tracker; the LLM will use this when looking up
  /// foods that aren't in OpenFoodFacts. Private to the user.
  usdaApiKey             String?
  /// Per-user sidebar order. JSON array of route paths ('/dashboard',
  /// '/quest', etc.) in the user's preferred sequence. Replaces the
  /// localStorage-only order so mobile + laptop stay in sync.
  /// Persists across devices, login sessions, and browser switches.
  /// Null = use the canonical default order from the frontend.
  navOrder               Json?
  /// TOTP secret, base32-encoded. Null when 2FA is not configured.
  /// Setup flow generates a fresh secret + recovery codes; user
  /// must verify one code before the secret is committed (and
  /// totpEnabled flips to true).
  totpSecret             String?
  /// Whether the user must complete a TOTP code at login. False
  /// during the grace window after first registration so the user
  /// isn't locked out if the authenticator app setup fails.
  totpEnabled            Boolean                 @default(false)
  /// Counter for failed login attempts. Reset on successful login.
  /// Used by the brute-force protection in the auth route.
  failedLogins           Int                     @default(0)
  /// When the account was last locked out due to too many failed
  /// attempts. Null = not locked. Resets on successful login.
  lockedUntil            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  portalLeaks            PortalLeak[]
  portalLeakDamageEvents PortalLeakDamageEvent[]

  @@index([email])
  @@index([username])
}

model Measurement {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric         MetricType
  value          Float
  unit           String
  notes          String?
  recordedAt     DateTime          @default(now())
  createdAt      DateTime          @default(now())
  /// Method used to take body-fat or weight readings. DEXA/BOD_POD
  /// are the gold standard; calipers/BIA are noisy; VISUAL/MANUAL
  /// are estimates. Morning report's body-comp insight weights by
  /// confidence (see api/src/lib/measurementSource.ts).
  source         MeasurementSource @default(UNKNOWN)
  /// Original .fit filename (when imported via the FitQuestBridge
  /// APK or via the web /import page). Lets the /import page's
  /// "Bridge uploads" panel show the source file. Null for
  /// legacy rows + manual in-app logs.
  sourceFilename String?

  @@unique([userId, metric, recordedAt])
  @@index([userId, metric, recordedAt])
  @@index([userId, metric, source, recordedAt])
  @@index([userId, sourceFilename])
}

model GeneticMax {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric    MetricType
  value     Float
  source    GeneticMaxSource @default(FORMULA)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, metric])
}

model Workout {
  id                     String                  @id @default(cuid())
  userId                 String
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                   WorkoutType
  name                   String?
  /// Total session duration in MINUTES (integer, rounded). Both the
  /// manual /workouts POST path and the FIT importer converge on
  /// this unit — the importer divides `totalTimerTime` (seconds) by
  /// 60 before persisting. Downstream readers (insights, morning
  /// report, correlations, xp.ts) all treat the value as minutes
  /// and divide by 60 again if they need seconds. A pre-fix bug
  /// stored FIT seconds verbatim; a one-time migration (see
  /// prisma/migrations/<ts>_fix_fit_duration_units/) divides those
  /// rows by 60.
  duration               Int?
  notes                  String?
  /// Post-session reflection. Distinct from `notes` which the live
  /// logger treats as preflight conditions logged before the first
  /// set. Surfaced only on the Finish screen so the user can capture
  /// how the workout went (not just how they expected it to go).
  /// Same string length budget — textareas cap at 2000 chars.
  postNotes              String?
  /// Which surface ingested this workout. See [WorkoutSource].
  /// Surfaced on /import → Bridge imports panel so the user can
  /// see which activities came in via the FitQuestBridge APK vs.
  /// a manual drag-and-drop into the web dropzone.
  importSource           WorkoutSource           @default(WEB)
  /// Original .fit filename (when importSource = BRIDGE). Lets
  /// the /import page render a per-file history so the user can
  /// see which specific bridge uploads made it. Null for web
  /// imports + legacy rows.
  sourceFilename         String?
  performedAt            DateTime                @default(now())
  createdAt              DateTime                @default(now())
  exercises              Exercise[]
  /// Per-second trackpoint stream (lat/lng/ele/timestamp + HR/cadence/power/
  /// speed/distance). Populated by the FIT importer from RecordMesg. Kept as
  /// JSONB rather than a separate table since we don't query into individual
  /// points and most workouts are short. Empty array when no GPS / no FIT.
  trackJson              Json                    @default("[]")
  /// Optional cardio block for non-set activities (hike / run / cycle /
  /// row / swim). Lets the user log a single distance + duration + pace
  /// without a full exercise breakdown. Stored as JSONB so we can
  /// add fields later without a migration. All fields are optional;
  /// `type = CARDIO` is the convention that drives the UI, but the
  /// block is independent of the type so future HIKING/RUNNING types
  /// can reuse the same shape.
  ///
  /// Shape: { distanceKm?: number, durationSec?: number, pace?:
  ///   'WALK_CASUAL'|'WALK_BRISK'|'JOG'|'RUN'|'SPRINT'|'CRUISE'|'INTERVALS',
  ///   elevationGainM?: number, avgHr?: number, maxHr?: number,
  ///   avgPaceSecPerKm?: number, source?: 'MANUAL'|'GPS' }
  cardio                 Json?
  /// Implausible set values flagged by the per-exercise plausibility
  /// detector (Bench 500kg, Squat 1000 reps, blanket > 500kg,
  /// etc.). Stored as JSONB so the morning report aggregator can
  /// query recent workouts and surface "this PR seems off" before
  /// the user loses trust in the LLM narrative. Null when no
  /// flags — saves space vs. an empty array.
  ///
  /// Shape: ValidityFlag[] =
  /// {exercise, setIndex, field: 'weight'|'reps', value, unit,
  ///  reason, severity: 'flag'|'block'}.
  validityFlags          Json?
  /// Breach damage events from this workout (one row per matched
  /// workout → one BreachDamageEvent, see UserBreachProgress docs).
  /// We don't define a back-relation on BreachDamageEvent because
  /// we look them up by user, not by workout — keeps the model
  /// surface small.
  breachDamageEvents     BreachDamageEvent[]
  /// Audit trail of leak damage events (workout → leak HP).
  /// Looked up by leak, not by user — so no back-relation on
  /// PortalLeakDamageEvent needed.
  portalLeakDamageEvents PortalLeakDamageEvent[]
  PendingSkillUnlock     PendingSkillUnlock[]

  @@unique([userId, performedAt])
  @@index([userId, importSource, performedAt(sort: Desc)])
}

model Exercise {
  id            String     @id @default(cuid())
  workoutId     String
  workout       Workout    @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name          String
  order         Int        @default(0)
  notes         String?
  // BodyPart IDs that this exercise primarily works.
  // Populated from a seed table by name lookup at insertion time
  // so users see the right muscles on the body without having to
  // tag exercises manually.
  musclesWorked BodyPart[] @default([])
  /// Superset pairing. Mirrors WorkoutTemplateExercise.groupIndex:
  /// exercises sharing the same groupIndex are paired and walked
  /// round-robin by the live logger. Null = linear.
  groupIndex    Int?
  sets          Set[]
  // Live-mode timestamps: when the user opened this exercise's first
  // set entry, and when they finished the last set of this exercise.
  // Null for workouts entered in bulk mode (legacy data, and any
  // workout where the user opted into the bulk flow).
  startedAt     DateTime?
  completedAt   DateTime?

  @@index([workoutId, groupIndex])
}

/// Why a set was not performed. Logged on the Set itself rather than
/// the Exercise so partial workouts (some sets done, one skipped for
/// an injury) are honest. INJURY skips do NOT count against streaks
/// or dailies; other reasons do.
enum SkipReason {
  INJURY
  ILLNESS
  FATIGUE
  EQUIPMENT
  SCHEDULE
  OTHER
}

model Set {
  id          String      @id @default(cuid())
  exerciseId  String
  exercise    Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  reps        Int
  weight      Float?
  duration    Int?
  rpe         Float?
  completed   Boolean     @default(true)
  order       Int         @default(0)
  // Set was not performed. If true, the workout's PR detection and
  // volume math ignore this row. The reason flows into the Status
  // avatar's "Condition" badge and the morning report.
  skipped     Boolean     @default(false)
  skipReason  SkipReason?
  // Live-mode timestamps. startedAt = user opened the set entry form
  // (or first set of a workout). completedAt = user tapped Continue.
  // Both null for workouts logged in bulk mode.
  //
  // restSeconds = seconds rested BEFORE this set (i.e. time between
  // the previous set's completedAt and this set's startedAt). For the
  // first set of a workout it's null. For the LAST set of a workout
  // it's the time from completedAt until the workout finished
  // (transitioning to the next exercise, or hitting Done).
  startedAt   DateTime?
  completedAt DateTime?
  restSeconds Int?
}

// =============================================================================
// Workout templates — saved workout patterns the user can reuse.
// Mirrors Workout → Exercise → Set but stores TARGET values (what the
// user aims to do) instead of ACTUAL values (what they did). Weight is
// intentionally absent — the user said "leave weight blank" so they
// fill it in live. RPE and duration are also not pre-stored.
//
// The full nested shape lives in three tables so we can:
//   - list a user's templates without loading exercises (just the row)
//   - duplicate a template in one tx (server endpoint below)
//   - export/import a template set alongside the user's data
//
// FKs cascade on delete — removing a template wipes its exercises +
// sets so the user can rename / replace without manual cleanup.
// =============================================================================

model WorkoutTemplate {
  id        String                    @id @default(cuid())
  userId    String
  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Human name, e.g. "Push Day 5x5", "Heavy Squat". Free text.
  name      String
  // Default workout type — preselected in setup phase, user can override.
  type      WorkoutType               @default(STRENGTH)
  // Free-form notes shown above the workout logger when this template
  // is picked (e.g. "Barbell bench first, accessories after, abs at end").
  notes     String?
  exercises WorkoutTemplateExercise[]
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([userId])
  @@index([userId, updatedAt])
}

model WorkoutTemplateExercise {
  id         String               @id @default(cuid())
  templateId String
  template   WorkoutTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // Exercise name (free text — same lookup as the live logger).
  name       String
  order      Int                  @default(0)
  /// Superset pairing. Two or more exercises that share the same
  /// groupIndex are paired — the live logger walks them round-robin
  /// (1A → 1B → 2A → 2B → ...) so the user alternates between
  /// exercises the way a real superset works. Null = walk linearly
  /// (no superset). The pairing is opt-in: bulk-mode + existing
  /// templates leave it null.
  groupIndex Int?
  sets       WorkoutTemplateSet[]

  @@index([templateId])
  @@index([templateId, groupIndex])
}

model WorkoutTemplateSet {
  id             String                  @id @default(cuid())
  exerciseId     String
  exercise       WorkoutTemplateExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  order          Int                     @default(0)
  // Target rep count. What the user aims for, not what they did.
  // The actual set rows at workout-commit time use reps (Set.reps).
  targetReps     Int
  // Optional target duration for timed exercises (plank, l-sit, etc).
  // Stored for completeness; weight is intentionally NOT stored.
  targetDuration Int?

  @@index([exerciseId])
}

model Pr {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          PrType
  exercise      String
  value         Float
  previousValue Float?
  achievedAt    DateTime @default(now())
  workoutId     String?

  @@index([userId, exercise, achievedAt])
}

model Skill {
  id             String               @id @default(cuid())
  className      ClassName
  tier           SkillTier
  name           String               @unique
  /// Short conceptual blurb: "What is this skill? Why does it
  /// matter?" Rendered on the SkillTree page under the skill
  /// name so users understand the point before diving into the
  /// test details. Existing skills (pre-v1) have null; new skills
  /// seed a value.
  blurb          String?
  /// Existing field. Holds the in-game perk summary (e.g.
  /// "+10% gold from PRs") rendered in the unlock modal. Not the
  /// focus of the SkillTree redesign — the focus is the test, not
  /// the perk — but kept for the in-game reward feedback loop.
  description    String
  /// Test details for unlocking this skill. JSON shape:
  ///   {
  ///     description: "How to perform" (form, technique),
  ///     safety:      "Use a spotter" (equipment / form cues),
  ///     metric:      "reps" | "weight:reps" | "weighted:reps:each"
  ///                 | "duration" | "distance" | "rounds",
  ///     threshold:   { ... metric-specific fields ... }
  ///   }
  /// The unlock endpoint validates the user's submitted result
  /// against this threshold. See api/src/lib/skillTest.ts for
  /// the metric-to-validator mapping.
  test           Json?
  /// Legacy SP cost. Default 0 since the SP economy is gone (the
  /// unlock is gated on the test passing + the per-skill prereqs).
  /// Column kept so historical rows don't need a migration; the
  /// api doesn't read or write it.
  cost           Int                  @default(0)
  prerequisites  String[]
  position       Int
  /// Branch within the class (e.g. JUGGERNAUT's "Squat", PHANTOM's
  /// "Pull"). The SkillTree page renders one column per branch, so
  /// every skill needs a branch label. Set by seedSkills; nullable
  /// for pre-v1 skills (which the page falls back to "Other" for).
  /// Stored as a plain String rather than an enum so future class /
  /// branch additions don't require a migration.
  branch         String?
  effects        Json
  userSkills     UserSkill[]
  /// Inbox of pending unlocks — one per (workout, set) that
  /// satisfied this skill's test. Unique on
  /// (userId, skillId, workoutId, matchedSetId) so re-running
  /// the matching pass is idempotent.
  pendingUnlocks PendingSkillUnlock[]
}

model Avatar {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hairStyle   HairStyle @default(SHORT)
  hairColor   String    @default("#56e88e")
  skinTone    String    @default("#d0a878")
  shirtColor  String    @default("#14d6e8")
  pantsColor  String    @default("#424553")
  accentColor String    @default("#f55cc4")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model UserSkill {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, skillId])
}

/// PendingSkillUnlock — created when a workout's exercises + sets
/// satisfy a locked skill's test threshold. The SkillTree page
/// shows the user's PENDING rows one at a time on mount; each
/// modal has "Unlock" (calls POST /skills/unlock with the
/// pendingUnlockId, which then marks the row UNLOCKED) and "Not
/// yet" (marks DISMISSED). Idempotent on
/// (userId, skillId, workoutId, setId) so re-running the matching
/// pass doesn't create duplicate rows.
///
/// The set data is snapshotted (setReps / setWeight / setDuration)
/// at insert time so the modal can render the matched set even
/// after the workout is later edited or deleted. Cascading
/// deletes (on user / workout / skill) still clean up.
model PendingSkillUnlock {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  /// The workout whose set triggered the eligibility. Cascades on
  /// delete so we don't end up with dangling pending rows.
  workoutId    String
  workout      Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  /// The specific Set within the workout that matched. We
  /// snapshot the relevant fields rather than joining, so the
  /// modal can render the matched set even after Set mutation.
  matchedSetId String
  setReps      Int?
  setWeight    Float?
  setDuration  Int?
  exerciseName String
  workoutDate  DateTime
  /// PENDING | DISMISSED | UNLOCKED. Default PENDING. The /skills
  /// /pending-unlocks endpoint only returns PENDING rows so the
  /// queue auto-drains as the user unlocks or dismisses.
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  @@unique([userId, skillId, workoutId, matchedSetId])
  @@index([userId, status, createdAt])
}

/// Home-base shield tier. Drives the visible home-base widget
/// and (eventually) the Breach boss combat damage multiplier —
/// a Breeched shield means the boss hits ~2x harder.
///
///  FORTIFIED    90-100   no monsters can enter, full cosmetic skin
///  STABLE       60-89    normal defense
///  COMPROMISED  30-59    portal leaks possible (Phase 2)
///  BREACHED     0-29     monsters trickle in + daily chip damage
enum ShieldTier {
  FORTIFIED
  STABLE
  COMPROMISED
  BREACHED
}

/// Per-user home-base state. One row per user; the shield value
/// is the core number (0-100). Tier is derived from shield but
/// stored too so we can index/filter by tier without recomputing.
///
/// shieldLastDecay tracks the last time we ran the nightly decay
/// check (for skipping work when nothing changed).
model HomeBase {
  id              String     @id @default(cuid())
  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 0-100. Starts at 100 (Fortified). Drops on missed-dailies /
  /// substance over-use, recovers on logged workouts + good habits.
  shield          Int        @default(100)
  tier            ShieldTier @default(FORTIFIED)
  /// Last time the nightly decay ran. Lets the cron skip
  /// no-op iterations (all values clamped, no events fired).
  shieldLastDecay DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

/// Penance templates — pre-built + user-customizable triggers that
/// adjust the home-base shield. Two scopes:
///   - System-wide defaults (userId = null): seeded on first DB
///     boot. Same for every user. Provides the baseline.
///   - User-created (userId set): the user can write their own
///     penance flavors + deltas if the defaults don't fit their
///     practice (e.g. a Muslim user adding a "Logged Fajr prayer"
///     penance with a +10 shield boost).
///
/// Shield delta range: -100 (catastrophic) to +50 (massive). Most
/// sit in ±20. The shield is clamped 0-100 after each application.
///
/// `key` is a stable identifier so the system can refer to
/// specific penances by name (e.g. "missed_workout" in the
/// event-triggering code). Unique per scope: a user's penance
/// with the same key as a system default shadows the default.
model PenanceTemplate {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 'missed_workout' | 'substance_overuse' | 'logged_mobility' |
  /// 'logged_cardio_30' | 'substance_checkin' | 'substance_free_day' |
  /// 'hit_protein_target' | 'hit_water_target' | 'completed_prayer' |
  /// 'missed_all_dailies' | 'custom'
  key         String
  /// One-line label surfaced in the home-base feed ("Skipped the
  /// forge" / "Tended the hinges").
  label       String
  /// Flavor text the LLM can fold into the morning report's
  /// narrative (≤ 200 chars).
  flavor      String?
  /// Signed integer. Positive repairs the shield; negative damages.
  shieldDelta Int
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([userId, key])
  @@index([userId, enabled])
}

/// Penance events — the audit trail of every shield adjustment.
/// One row per fire so we can render the home-base feed and
/// reconstruct the shield value at any past date. User-only
/// (system penances just write rows for the affected user).
///
/// `source` describes what fired the penance:
///   'workout_commit'     — workout POST endpoint
///   'substance_log'      — substance POST endpoint
///   'daily_missed'       — end-of-day cron, daily missed
///   'daily_completed'    — daily completed
///   'nutrition_target'   — hit daily nutrition goal
///   'auto_decay'         — nightly decay sweep
///   'manual'             — admin override
model PenanceEvent {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  penanceKey  String
  label       String
  /// The actual delta applied (signed). Negative = damage.
  shieldDelta Int
  /// shield value AFTER the delta was applied. Lets the UI render
  /// "Shield 80 → 65 (-15)" without needing to sort + sum.
  shieldAfter Int
  tierAfter   ShieldTier
  /// What fired the penance: 'workout_commit' | 'substance_log' |
  /// 'daily_missed' | 'daily_completed' | 'nutrition_target' |
  /// 'auto_decay' | 'manual'.
  source      String
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([userId, source])
}

/// Shop items the user can buy with gold. Each item has a fixed
/// cost and a single effect (applied on purchase or held in the
/// user's inventory until consumed, depending on the effect).
/// Seeded with the 4 base items: Vital Tonic, War Tincture,
/// Continuity Rune, Forge Tonic.
model ShopItem {
  id                String   @id @default(cuid())
  /// Stable string key used by the API and frontend to look the
  /// item up (e.g. "vital_tonic", "war_tincture"). Don't change
  /// without a migration — purchases reference this.
  key               String   @unique
  name              String
  /// Short flavor text shown in the shop modal under the name.
  description       String
  cost              Int
  /// "heart_refill" | "raid_buff" | "streak_shield" | "pr_doubler" | ...
  /// Consumed-item types (raid_buff, pr_doubler) have an
  /// effectDurationSec; passive-item types (heart_refill) have null.
  effectKey         String
  effectValue       Int      @default(0)
  effectDurationSec Int?
  /// When false, the item is hidden from the shop (admin toggle).
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  purchases Purchase[]

  @@index([active])
}

/// User purchases of shop items. Each row is either:
///   - already consumed (consumedAt != null) — for items that
///     apply their effect immediately on purchase (Vital Tonic:
///     +1 heart right now). The row stays in the table for audit.
///   - active inventory (consumedAt == null AND now < expiresAt)
///     — for items with a duration (War Tincture, Forge Tonic,
///     Continuity Rune). The effect applies while this row exists.
///   - expired (now >= expiresAt) — lazy-cleaned by background
///     queries; query helpers filter by expiresAt > now to ignore
///     these transparently.
model Purchase {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        ShopItem  @relation(fields: [itemId], references: [id], onDelete: Restrict)
  purchasedAt DateTime  @default(now())
  consumedAt  DateTime?
  expiresAt   DateTime?

  @@index([userId, purchasedAt])
  @@index([userId, consumedAt])
}

/// World-boss soulstone drops. Any world boss always drops one of
/// these in addition to its normal drops; if the user doesn't use
/// it within 24h it "disintegrates" (the row is lazy-cleaned by
/// background queries). Using the soulstone triggers a class
/// respec — the user picks a new class, and their skill unlocks
/// for the old class are archived (not deleted) so they can be
/// re-unlocked if the user switches back.
model Soulstone {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// For display in the inventory / shop: which boss dropped it.
  /// E.g. "Gains Goblin" (Maw) or "Gripping Ghoul" (Heroic Breach).
  bossName   String
  /// Boss difficulty tier at time of drop. Cosmetic — used for
  /// sort order + UI badge (e.g. "Soulstone from a Tier 3 boss").
  bossTier   Int       @default(1)
  droppedAt  DateTime  @default(now())
  /// droppedAt + 24h. After this, the stone "disintegrates" and
  /// the row is ignored by all queries.
  expiresAt  DateTime
  consumed   Boolean   @default(false)
  consumedAt DateTime?

  @@index([userId, droppedAt])
  @@index([userId, expiresAt])
}

/// Hardcore-mode heart-loss audit. One row per (user, local-date,
/// trigger-kind). The unique index makes the morning-report sweep
/// naturally idempotent — re-fetching /morning-report the same day
/// is a no-op for hearts because the unique constraint blocks dupes.
///
/// Possible trigger kinds (see HeartLossTrigger enum):
///   MISSED_WORKOUT      — yesterday was a RoutineDay workout day
///                          and no Workout row landed in that window.
///   MISSED_ALL_DAILIES  — every expected daily (incl. spiritual
///                          prayers the user committed to) was
///                          skipped yesterday.
///   SUBSTANCE_CAFFEINE  — yesterday's caffeine log count exceeded
///                          the Hardcore cap.
///   SUBSTANCE_ALCOHOL   — rolling 7-day alcohol count exceeded
///                          the Hardcore cap.
///   SUBSTANCE_NICOTINE  — rolling 7-day nicotine count exceeded
///                          the Hardcore cap.
///   ZERO_SPIRITUAL      — no spiritual activity (any prayer type,
///                          mass, etc.) was logged yesterday, even
///                          if the user hasn't configured dailies.
model HeartLossEvent {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       HeartLossTrigger
  /// Local-date (YYYY-MM-DD) the penalty applies to. Stored as a
  /// DATE (not timestamptz) so the unique constraint is per
  /// calendar day in the user's tz, not per UTC instant.
  sourceDate DateTime         @db.Date
  /// Human-readable explanation of what fired (e.g. "3 caffeine
  /// logs on 2026-06-21 vs cap of 3"). Surfaced in the morning
  /// report penalty ledger.
  details    String?
  firedAt    DateTime         @default(now())

  @@unique([userId, kind, sourceDate])
  @@index([userId, firedAt])
}

// ============================================================
// The Breach — level-10 unlock + boss combat
// ============================================================
//
// At level 10 the Nexus reveals a sealed leak: a black hole
// in the constellation that the player can enter. Each user
// always has exactly one ACTIVE breach boss at any time. On
// kill the server rotates in a fresh boss weighted by class
// affinity + recent kills (no repeats within 10).
//
// Combat: each workout commit deals damage to the active boss
// based on whether the workout's exercises match the boss's
// `preferredTags`. Match → deal damage via the existing
// raidDamage pipeline. Mismatch → heal the boss (encourages
// the user to focus on the boss's weak points).
//
// Daily damage cap: 1.5× boss.maxHp — bounds the "I just did a
// 5-hour lifting session, that should solo the boss" abuse.

enum BreachTier {
  MINOR // 1-3 difficulty, early Breach bosses
  ELITE // 4-6 difficulty, mid Breach
  LEGENDARY // 7-9 difficulty, post-class bosses
  APEX // 10+, end-game content
}

/// Difficulty rating for Breach bosses. Separate from tier —
/// tier is the drop-table bucket (what you get for killing it)
/// while difficulty is how hard it is to wear down.
enum BreachDifficulty {
  ONE
  TWO
  THREE
  FOUR
  FIVE
}

/// Class affinity tag. Matches the User.class enum so the
/// rotation algorithm can weight new bosses toward the user's
/// current class (more variety over time, but always feeling
/// relevant).
enum BreachClassAffinity {
  JUGGERNAUT
  BERSERKER
  PHANTOM
  SCOUT
  TRACER
  ORACLE
  ANY
}

/// Status of the user's Breach progress.
enum BreachProgressStatus {
  LOCKED // not yet at level 10
  ACTIVE // boss is alive, fighting in progress
  VICTORY // boss just died, drops pending + rotating next
  COOLDOWN // user died; 24h before re-attempting
}

/// The Breach boss pool. One row per boss. Seeded once on first
/// DB boot (50+ bosses). User-progress references current boss
/// via UserBreachProgress.currentBossId.
model BreachBoss {
  id                 String               @id @default(cuid())
  name               String
  lore               String?
  /// Difficulty 1-5 stars. Determines starting HP and the daily
  /// damage cap (capped at 1.5× maxHp regardless).
  difficulty         BreachDifficulty
  /// Tier — drives drop table (MINOR = common loot, APEX = epic+).
  tier               BreachTier
  /// Starting HP at full health. Scaled by difficulty:
  ///   1-star: 500 HP, 2-star: 800, 3-star: 1200,
  ///   4-star: 1800, 5-star: 2500.
  maxHp              Int
  /// Current HP. Defaults to maxHp. Decremented on successful
  /// workouts, incremented on mismatched ones (capped at maxHp).
  hp                 Int
  /// Class affinity. ANY = no preference (random in rotation).
  classAffinity      BreachClassAffinity  @default(ANY)
  /// Body-part tags this boss is "weak to" — workouts matching
  /// these (by exercise name OR workout type) deal full damage.
  /// JSON array of strings like ["chest", "triceps", "heavy_compound"].
  /// Workout classification happens in lib/breachDamage.ts — the
  /// boss just stores the target tags.
  preferredTags      Json
  /// Bonus tags that ALWAYS count as weak (rare categories that
  /// make the boss more interesting to fight). E.g. "marathon"
  /// or "tabata" or "nordic_curl".
  bonusTags          Json                 @default("[]")
  /// Short flavor text surfaced when the boss appears. Two
  /// sentences max — sets the tone for the encounter.
  intro              String?
  /// Visual: single emoji glyph until sprite overhaul lands.
  /// Slot for the sprite-overhaul commit to fill.
  spriteEmoji        String               @default("◉")
  spriteColor        String               @default("#dc2626")
  createdAt          DateTime             @default(now())
  UserBreachProgress UserBreachProgress[]
  BreachDamageEvent  BreachDamageEvent[]

  @@index([tier, difficulty])
}

/// Per-user Breach state. One row per user. Created lazily on
/// first /breach GET after level 10 (or on first damage event).
///
/// Lifecycle:
///   LOCKED → ACTIVE (level 10 unlock)
///   ACTIVE → VICTORY (boss hp <= 0)
///   VICTORY → ACTIVE (next boss rotated in)
///   ACTIVE → COOLDOWN (user died; 24h before re-attempting)
///   COOLDOWN → ACTIVE (timer elapsed; same boss with +25% HP)
model UserBreachProgress {
  id            String               @id @default(cuid())
  userId        String               @unique
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Current active boss. NULL when LOCKED.
  currentBossId String?
  currentBoss   BreachBoss?          @relation(fields: [currentBossId], references: [id])
  /// User's current HP against the boss. 0 = victory, hp <= 0
  /// (post-clamp) triggers rotation.
  bossHp        Int                  @default(0)
  /// Status. LOCKED until level 10 unlocks the Breach.
  status        BreachProgressStatus @default(LOCKED)
  /// Cumulative kills. Drives "no repeats within N" rotation.
  kills         Int                  @default(0)
  /// Cumulative deaths. Drives +25% HP re-encounter rule.
  deaths        Int                  @default(0)
  /// Last time the user died. NULL on first encounter.
  lastDeathAt   DateTime?
  /// Damage dealt to the current boss in the current local day.
  /// Reset on day rollover. Bounded by 1.5× boss.maxHp — anything
  /// over that is rejected at the workout-commit handler.
  damageToday   Int                  @default(0)
  /// YYYY-MM-DD (user's tz) for the damageToday counter. Lets the
  /// daily-cap check work correctly across midnight boundaries.
  damageDayKey  String?
  /// When the Breach was first unlocked (level 10 reached). NULL
  /// until then. Drives the unlock cutscene.
  unlockedAt    DateTime?
  /// Last 10 boss IDs the user has fought, newest first. Used by
  /// the rotation algorithm to avoid repeats. JSON array.
  recentBossIds Json                 @default("[]")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status])
}

/// Per-user damage event log. One row per (user, workout) that
/// touched the Breach. Used for the "recent damage" feed in
/// the Breach UI + audit trail for "why didn't this workout deal
/// damage" debugging.
model BreachDamageEvent {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bossId      String
  boss        BreachBoss @relation(fields: [bossId], references: [id], onDelete: Cascade)
  workoutId   String?
  workout     Workout?   @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  /// Damage dealt. Negative = heal (mismatched workout).
  damage      Int
  /// Boss HP after the event. Lets the UI render a damage
  /// timeline without re-deriving.
  bossHpAfter Int
  /// Whether the workout matched the boss's preferredTags.
  /// 'matched' | 'mismatched' | 'partial'.
  matchType   String
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([bossId, createdAt])
}

// ============================================================
// Portal leaks — small home-base encounters spawned when the
// user's shield drops below COMPROMISED. One leak can be active
// at a time; resolved leaks enter a 24h cooldown. Match the leak's
// preferredTags via workout commits to damage it; mismatched
// workouts feed it. Defeat = loot drop. Overwhelm = penance
// + shield drain.
// ============================================================

enum PortalLeakStatus {
  ACTIVE // currently damaging the user / being damaged by them
  DEFEATED // user reduced HP to 0; pending loot claim
  OVERWHELMED // leak HP exceeded overwhelm threshold; cooldown
  EXPIRED // leak aged out without resolution; cooldown
}

model PortalLeak {
  id                    String                  @id @default(cuid())
  userId                String
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Random monster name pulled from the seed pool. Lets the UI
  /// show a themed encounter without LLM cost.
  monsterName           String
  /// Visual glyph (until sprite-overhaul lands). One of the
  /// portal-monster icons from lib/portalLeaks.ts.
  monsterEmoji          String
  /// Visual color for the leak ring + status chip.
  monsterColor          String
  /// One-sentence flavor text shown on spawn notification.
  intro                 String
  /// Body-part / muscle tags this leak is "weak to". Workout
  /// commits that match deal damage; mismatched workouts heal
  /// the leak by a small amount. JSON array of strings.
  preferredTags         Json
  /// Bonus tags that grant extra damage. Rare category bonus
  /// (e.g. "cardio" on a strength leak) — same shape as Breach.
  bonusTags             Json                    @default("[]")
  /// Current HP. Starts at maxHp. Decremented by matched
  /// workouts, incremented by mismatched ones (capped at
  /// maxHp * OVERWHELM_CAP_MULT).
  hp                    Int                     @default(100)
  /// Starting HP. Sized smaller than Breach bosses (80-160)
  /// since leaks are 1-shot encounters, not boss fights.
  maxHp                 Int                     @default(100)
  /// Lifecycle state. ACTIVE → DEFEATED (user kills) or
  /// OVERWHELMED (leak kills user) or EXPIRED (48h timer).
  status                PortalLeakStatus        @default(ACTIVE)
  spawnedAt             DateTime                @default(now())
  resolvedAt            DateTime?
  /// ItemDef.id of the loot that drops on defeat. Null until
  /// resolved. Set when the leak is created so the loot is
  /// deterministic per encounter (the user's "prize" rolls
  /// at spawn, not at claim, so it's stable).
  itemDrop              String?
  /// Reason text for the resolution (e.g. "you sealed the leak",
  /// "the leak overwhelmed you"). Surfaced in the toast.
  resolvedReason        String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  /// Where this leak came from. 'AMBIENT' (default) — the existing
  /// random spawn when the homebase shield drops. 'BREACH' — a
  /// leak that escaped from the Breach world (e.g. user defeated
  /// the Maw and the wound bled). Lets the UI show a special
  /// banner and the /breach raid page filter for them.
  worldSource           PortalLeakSource        @default(AMBIENT)
  PortalLeakDamageEvent PortalLeakDamageEvent[]

  @@index([userId, status])
  @@index([userId, spawnedAt])
  @@index([userId, worldSource])
}

enum PortalLeakSource {
  AMBIENT // regular homebase-shield leak
  BREACH // escaped from the Breach world
}

model PortalLeakDamageEvent {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  leakId      String
  leak        PortalLeak @relation(fields: [leakId], references: [id], onDelete: Cascade)
  workoutId   String?
  workout     Workout?   @relation(fields: [workoutId], references: [id], onDelete: SetNull)
  /// Damage dealt. Negative = leak fed (mismatched workout).
  damage      Int
  /// Leak HP after the event. Lets the UI render a timeline
  /// without re-deriving.
  leakHpAfter Int
  /// 'matched' | 'mismatched' | 'partial' | 'bonus'.
  matchType   String
  createdAt   DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([leakId, createdAt])
}

model Party {
  id           String            @id @default(cuid())
  name         String
  createdAt    DateTime          @default(now())
  members      PartyMember[]
  raids        Raid[]
  invites      PartyInvite[]
  teamWorkouts TeamWorkout[]
  camaraderie  PartyCamaraderie?
  buff         PartyBuff?
}

model PartyMember {
  id       String     @id @default(cuid())
  partyId  String
  party    Party      @relation(fields: [partyId], references: [id], onDelete: Cascade)
  userId   String     @unique
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())
}

// ============================================================
// Team workout mode (the social moat) — see fitquest_roadmap.md
// §26–§34. The team session is purely orchestration: each
// participant still logs their own per-user Workout row so XP,
// PR detection, raid damage, etc. all stay unified. The
// TeamWorkout row tracks the shared lifecycle (pending →
// active → completed) and TeamParticipant tracks per-member
// status (invited/joined/confirmed).
// ============================================================

enum TeamWorkoutStatus {
  PENDING // leader has invited members; nobody has joined yet
  ACTIVE // at least one member has joined; in progress
  COMPLETED // all members confirmed "done"
  ABANDONED // leader cancelled or 1h idle
}

enum TeamParticipantStatus {
  INVITED // invitee hasn't responded
  ACCEPTED // invitee accepted; will participate
  DECLINED // invitee declined
  JOINED // active session, hasn't yet committed a workout
  CONFIRMED // workout committed + tapped "I'm done"
  NO_SHOW // invited/accepted but never joined within 30 min
}

model TeamWorkout {
  id          String            @id @default(cuid())
  partyId     String
  party       Party             @relation(fields: [partyId], references: [id], onDelete: Cascade)
  /// User who hit "Start team workout". Implicit-accept.
  leaderId    String
  leader      User              @relation("TeamWorkoutLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  startedAt   DateTime          @default(now())
  endedAt     DateTime?
  status      TeamWorkoutStatus @default(PENDING)
  /// Optional shared routine name (leader's choice; surfaced in
  /// the split-pane as the "session focus" tag).
  routineName String?
  /// Set when COMPLETED: all participants confirmed. Drives the
  /// +5 camaraderie, +10% raid damage (24h), and the
  /// "Side by Side" achievement.
  completedAt DateTime?

  participants TeamParticipant[]

  @@index([partyId, status])
  @@index([leaderId])
}

model TeamParticipant {
  id            String                @id @default(cuid())
  teamWorkoutId String
  teamWorkout   TeamWorkout           @relation(fields: [teamWorkoutId], references: [id], onDelete: Cascade)
  userId        String
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        TeamParticipantStatus @default(INVITED)
  /// Per-user Workout row created when the participant commits
  /// their session. Same row that single-player mode would have
  /// produced — XP/PRs/raid damage flow from this.
  workoutId     String?
  /// When the user tapped Accept / Decline / Joined / Confirmed.
  respondedAt   DateTime?
  confirmedAt   DateTime?

  @@unique([teamWorkoutId, userId])
  @@index([userId, status])
}

// ============================================================
// PartyCamaraderie — per-party 0–100 score, surfaced on /party
// as "🔥 67/100 — Iron Bond". Drives the unlocks in roadmap
// §32: 50+ heirloom slot, 75+ shared-daily auto-completion,
// 100+ free class change.
// ============================================================

model PartyCamaraderie {
  partyId   String   @id
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  /// 0..100. Capped and floored at the edges so negative events
  /// (leaving) don't drop below 0.
  score     Int      @default(0)
  /// Title tier based on score — kept as a string so the
  /// threshold names stay in app code, not the schema.
  tier      String   @default("Cold")
  /// Set of (reason, delta) entries for the last 30 days so
  /// the /party page can render a "why is my score X?" log.
  history   Json     @default("[]")
  updatedAt DateTime @updatedAt
}

/// Party-wide buffs granted by social events. Today the only
/// source is the team-workout completion (+10% raid damage for
/// 24h, per roadmap §30), but the schema leaves room for future
/// buffs like +XP from co-op dailies.
model PartyBuff {
  partyId         String   @id
  party           Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  raidDmgBonusPct Int      @default(0)
  expiresAt       DateTime
  reason          String
}

model Raid {
  id            String             @id @default(cuid())
  partyId       String
  party         Party              @relation(fields: [partyId], references: [id], onDelete: Cascade)
  bossName      String
  bossHp        Int
  bossMaxHp     Int
  status        RaidStatus         @default(ACTIVE)
  startedAt     DateTime           @default(now())
  endedAt       DateTime?
  contributions RaidContribution[]
}

model RaidContribution {
  id            String   @id @default(cuid())
  raidId        String
  raid          Raid     @relation(fields: [raidId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  damage        Int
  source        String
  contributedAt DateTime @default(now())

  @@index([raidId, userId])
}

model Achievement {
  id               String              @id @default(cuid())
  key              String              @unique
  name             String
  description      String
  category         AchievementCategory
  icon             String
  criteria         Json
  points           Int                 @default(10)
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

/// User-initiated pause on one or more plateau-detection kinds.
/// When a row exists with `resumeAt > now`, detectPlateaus skips
/// those rules (so a planned deload week doesn't spam "no PRs
/// in 30 days"). `kind = 'ALL'` pauses every detector. Created via
/// /plateaus pause endpoint; auto-expires via `resumeAt`.
model PlateauPause {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      PlateauKind
  pausedAt  DateTime    @default(now())
  /// Future timestamp. While now < resumeAt the rule is paused.
  resumeAt  DateTime
  reason    String?
  createdAt DateTime    @default(now())

  @@index([userId, resumeAt])
}

/// Cached plateau detection output, refreshed weekly by the cron
/// job in api/src/index.ts (Sunday 22:00 local). Lets the
/// dashboard surface a stale-badge count without forcing a
/// morning-report regeneration on every page load. Shape:
/// { kind, exercise?, since, label, severity, note, context }.
model PlateauSnapshot {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Sunday-of-week in the user's local timezone (YYYY-MM-DD).
  /// One row per user per week; the weekly cron overwrites.
  weekStart   String
  /// JSON array of Plateau shape (see api/src/lib/plateau.ts).
  plateaus    String
  /// Convenience count so the badge query doesn't have to parse
  /// the JSON. 0 means clean week.
  flagCount   Int      @default(0)
  generatedAt DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId, generatedAt])
}

/// Ignatian examen response — Sunday-evening reflection. Three
/// open-text fields (consoled / desolated / godsPresence) plus an
/// optional notes overflow. Surfaced in the morning report's
/// spiritual section ("4 of last 5 Sundays logged").
model ExamenResponse {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Sunday-of-week in the user's local timezone (YYYY-MM-DD).
  /// One response per user per week (latest wins via UPSERT).
  weekStart    String
  consoled     String
  desolated    String
  godsPresence String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId, createdAt])
}

enum PlateauKind {
  NO_PR_RECENT
  ONE_RM_REGRESSION
  VOLUME_REGRESSION
  WEIGHT_FLATLINE
  METRIC_FLATLINE
  ALL
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?
  /// 'FULL' = normal authenticated session. 'TOTP_PENDING' = the
  /// user has supplied their password but hasn't yet passed the
  /// TOTP step; expires in 5 min and is consumed by /auth/login/totp
  /// to upgrade to 'FULL'.
  kind      String   @default("FULL")
}

model UserWorldProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId     String // static key, e.g. "spire-1"
  /// World cycle this progress belongs to. Defaults to 1. For the
  /// Breach world, increments each time the user defeats the Maw and
  /// the world regenerates — so a single user has up to N progress
  /// rows per breach level (one per cycle). Old cycles are kept for
  /// history; the quest UI shows the most recent.
  cycle       Int       @default(1)
  completed   Boolean   @default(false)
  attempts    Int       @default(0)
  bestScore   Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, levelId, cycle])
  @@index([userId])
}

enum BodyPart {
  // Head + spine
  HEAD
  NECK
  TRAPS
  // Torso — chest + back + core
  PECTORAL
  BACK_UPPER
  BACK_LOWER
  LAT_L
  LAT_R
  ABS
  OBLIQUE_L
  OBLIQUE_R
  // Legacy / overview parts (kept for backward compat)
  CHEST
  HIP_L
  HIP_R
  // Shoulders + arms
  SHOULDER_L
  SHOULDER_R
  ROTATOR_CUFF_L
  ROTATOR_CUFF_R
  BICEP_L
  BICEP_R
  TRICEP_L
  TRICEP_R
  FOREARM_L
  FOREARM_R
  WRIST_L
  WRIST_R
  // Hips + legs
  GLUTE_L
  GLUTE_R
  ADDUCTOR_L
  ADDUCTOR_R
  ABDUCTOR_L
  ABDUCTOR_R
  QUAD_L
  QUAD_R
  HAMSTRING_L
  HAMSTRING_R
  KNEE_L
  KNEE_R
  CALF_L
  CALF_R
  ANKLE_L
  ANKLE_R
  FOOT_L
  FOOT_R
}

model PainLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bodyPart  BodyPart
  intensity Int // 0-10
  notes     String?
  loggedAt  DateTime @default(now())

  @@index([userId, bodyPart])
  @@index([userId, loggedAt])
}

/// One-shot task that doesn't recur (use Habit for recurring
/// tick-able things, Daily for scheduled daily check-ins, this
/// for finite "register for the marathon" / "schedule PT appt"
/// items). Marking complete grants XP scaled by priority; no
/// penalty for missing.
model TodoItem {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Short title (required). Display-first line in the list.
  title       String
  /// Optional longer description / notes. Not shown in the list
  /// row but rendered in the detail / edit pane.
  description String?
  /// Optional due date — surfaces a "due today" / "overdue" badge
  /// in the list. Time-agnostic (date only, no tz) so the
/// client interprets in their local timezone.
  dueDate     DateTime?
  /// LOW = 10 XP, MEDIUM = 20, HIGH = 30. Awarded on transition
  /// to DONE only (re-completing an already-DONE todo does NOT
  /// re-award).
  priority    TodoPriority   @default(MEDIUM)
  /// OPEN or DONE. Single state field; we don't model ARCHIVED or
  /// DELETED — soft-delete just flips status to DONE with the
  /// deletedAt-on-OPEN idea, or use a separate deletedAt field if
  /// soft-delete is needed later.
  status      TodoStatus     @default(OPEN)
  /// When the user marked it DONE. Null while OPEN. Together
  /// with status lets the list sort by "recently completed".
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, status])
  @@index([userId, dueDate])
  @@index([userId, createdAt])
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

enum TodoStatus {
  OPEN
  DONE
}

// Persistent notification feed. Unlocks, level-ups, penance events,
// etc. previously fired only as ephemeral modals + the sound bus —
// if the user dismissed the modal quickly (or was away from the
// page) the event was lost. Each Notification row is one event; the
// /notifications inbox aggregates them, supports read/dismiss, and
// drives the unread-count badge in the top bar.
model Notification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Coarse category, drives the icon + the inbox filter tabs.
  category  NotificationCategory
  /// Machine-readable event kind (e.g. 'level_up', 'skill_unlock',
  /// 'penance', 'shop_purchase'). Free-form within a category so we
  /// can add kinds without a migration.
  kind      String
  /// One-line summary shown in the list row.
  title     String
  /// Optional longer body shown when the row is expanded.
  body      String?
  /// Optional deep-link the row navigates to when clicked (e.g.
  /// '/skills' for an unlock, '/homebase' for a penance event).
  link      String?
  /// Arbitrary structured payload for the event (xp gained, skill
  /// id, level number, etc). Read by the client for richer rendering.
  payload   Json?
  /// Null while unread. Set when the user opens/marks-read. The
  /// unread-count badge is COUNT(*) WHERE readAt IS NULL.
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

enum NotificationCategory {
  SKILL
  PENANCE
  SHOP
  SYSTEM
  ACHIEVEMENT
  LEVEL
}

// Add new muscle groups to BodyPart enum
// PECTORAL, ABS, OBLIQUE_L/R, TRICEP_L/R, TRAPS, LAT_L/R,
// GLUTE_L/R, ADDUCTOR_L/R, ABDUCTOR_L/R, ROTATOR_CUFF_L/R

model Routine {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Target workouts per week (1-14). Default 3.
  weeklyGoal        Int       @default(3)
  // Consecutive weeks where the user met their weekly goal.
  currentStreak     Int       @default(0)
  longestStreak     Int       @default(0)
  // ISO date (YYYY-MM-DD) of the Monday of the last week that was completed.
  // Used to detect when the user crosses a week boundary.
  lastCompletedWeek String?
  // When the streak was last touched (set / incremented / reset).
  streakUpdatedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum WorldBossStatus {
  LOCKED // world not yet cleared
  ACTIVE // unlocked, taking damage
  DEFEATED // hp <= 0
}

model WorldBoss {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  worldId    String // 'spire', 'glade', etc.
  bossName   String
  bossGlyph  String // single character icon
  bossHp     Int // current HP (decreases as damaged)
  bossMaxHp  Int // total HP
  status     WorldBossStatus @default(LOCKED)
  /// Cycle counter. Increments each time the user defeats this
  /// world's boss and the world resets. For the Breach world
  /// this means a new Maw variant + new level requirements. For
  /// other worlds it's always 1 (no reset behavior). Used in the
  /// UI to disambiguate old vs new world progress (e.g. "Cleared
  /// during the Maw Reborn cycle (3)").
  cycle      Int             @default(1)
  unlockedAt DateTime?
  defeatedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([userId, worldId])
  @@index([userId])
}

enum PartyInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model PartyInvite {
  id              String            @id @default(cuid())
  partyId         String
  party           Party             @relation(fields: [partyId], references: [id], onDelete: Cascade)
  inviterId       String
  inviter         User              @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)
  // Resolved to a user at create time. If null, the invite was sent
  // to a username that doesn't exist (yet).
  inviteeId       String?
  invitee         User?             @relation("Invitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  inviteeUsername String // captured at send time for display
  status          PartyInviteStatus @default(PENDING)
  message         String? // optional message from inviter
  createdAt       DateTime          @default(now())
  respondedAt     DateTime?
  expiresAt       DateTime // 7 days from creation

  @@index([inviteeId, status])
  @@index([partyId])
}

enum SpiritualSubclass {
  CATECHUMEN // Stage 1: novice preparing
  CRUSADER // Stage 2: vowed fighter
  TEMPLAR // Stage 3: elite religious order
}

enum PrayerType {
  ROSARY
  MASS
  SCRIPTURE
  CONTEMPLATION
  LITURGY_HOURS
  CONFESSION
  OTHER
}

model PrayerLog {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Built-in prayer type. Null when logging a user-defined custom
  /// spiritual practice (use `dailyId` instead).
  type        PrayerType?
  /// When `type` is null, this points at the user-defined practice
  /// (USER + SPIRITUAL daily) the user logged.
  dailyId     String?
  daily       Daily?      @relation(fields: [dailyId], references: [id], onDelete: SetNull)
  durationMin Int         @default(15)
  notes       String?
  xpAwarded   Int         @default(0)
  goldAwarded Int         @default(0)
  loggedAt    DateTime    @default(now())

  @@index([userId, loggedAt])
}

// ============================================================
// Daily routine — per-user-per-day-of-week workout schedule + notes.
// Days are stored as 0-6 (Sun-Sat). One RoutineDay row per user-day.
// workout=false is a rest day but the user can still complete the
// daily (it's just "did I show up today" tracking).
// ============================================================

enum DayOfWeek {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

model RoutineDay {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       DayOfWeek
  workout   Boolean   @default(false)
  notes     String?
  updatedAt DateTime  @updatedAt

  @@unique([userId, day])
  @@index([userId])
}

// ============================================================
// Dailies — user-defined recurring tasks (Habitica-style).
// Each Daily has a name, optional category, and per-day-of-week
// schedule. The built-in "Workout" daily is auto-generated from
// RoutineDay rows and surfaced alongside user dailies.
// ============================================================

enum DailyCategory {
  USER // generic user-defined daily
  WORKOUT // derived from RoutineDay (read-only here)
  SPIRITUAL // derived from User.spiritualDailyPrayers
  SLEEP // optional sleep-related dailies (auto-derived)
}

model Daily {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   DailyCategory @default(USER)
  // Days this daily is due on (0-6 Sun-Sat). If empty array, due every day.
  // Built-in dailies (WORKOUT/SPIRITUAL/SLEEP) auto-populate this.
  days       DayOfWeek[]
  // Master switch for "show on /today". When false, the daily is
  // archived from the user's daily checklist (still loggable, just
  // not auto-due). This is the user-defined analog of toggling a
  // built-in PrayerType on/off in User.spiritualDailyPrayers.
  // Defaults true so newly-created custom practices appear on
  // /today immediately (matching the previous implicit behavior
  // where any non-archived SPIRITUAL row showed up).
  isDaily    Boolean       @default(true)
  notes      String?
  // Reward on completion (gold/xp). 0 = no reward. Default 5/2.
  goldReward Int           @default(5)
  xpReward   Int           @default(2)
  // Ordering for display
  sortOrder  Int           @default(0)
  archived   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  logs       DailyLog[]
  prayerLogs PrayerLog[]

  @@index([userId, archived])
}

model DailyLog {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyId        String
  daily          Daily    @relation(fields: [dailyId], references: [id], onDelete: Cascade)
  // Stored so built-in dailies (which aren't real Daily rows) can
  // still be logged. Format e.g. "WORKOUT:MON".
  dailyKey       String
  goldDelta      Int      @default(0)
  xpDelta        Int      @default(0)
  loggedAt       DateTime @default(now())
  /// Original .fit filename (when imported via the FitQuestBridge
  /// APK). Lets the /import page's "Bridge uploads" panel show
  /// the source file. Null for legacy rows + manual in-app logs.
  sourceFilename String?

  @@index([userId, dailyKey, loggedAt])
  @@index([userId, loggedAt])
  @@index([dailyId, loggedAt])
  @@index([userId, sourceFilename])
}

// ============================================================
// Supplements — daily-tracked intakes (creatine, vitamin D, etc.).
// The "creatine on ≥3 of last 7 days" check pulls from this table
// rather than a free-floating User.creatine boolean, so it stays
// honest even when the user skips days.
// ============================================================

model SupplementLog {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Free-form name (e.g. "Creatine", "Vitamin D3", "Fish Oil").
  // Matched case-insensitively for the "creatine active" check.
  name    String
  // Optional dose (mg). For creatine the common dose is 5000.
  doseMg  Int?
  takenAt DateTime @default(now())

  @@index([userId, name, takenAt])
}

// ============================================================
// Habits — user-defined Habitica-style +/- behaviors.
// "POSITIVE" habits reward gold/XP when checked (e.g., "drank
// water"). "NEGATIVE" habits penalize when checked (e.g., "ate
// junk food"). Each press is logged once per day; multiple
// presses per day accumulate reward/penalty.
// ============================================================

enum HabitDirection {
  POSITIVE // checking gives reward
  NEGATIVE // checking takes a penalty
}

model Habit {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  notes      String?
  direction  HabitDirection
  // Reward/penalty applied per check. Kept simple: gold + xp only.
  // For POSITIVE habits this is what you GAIN; for NEGATIVE it's
  // what you LOSE (the system applies the opposite sign).
  goldReward Int            @default(5)
  xpReward   Int            @default(2)
  // Display icon (single char/glyph). Defaults are picked by the
  // UI based on direction.
  icon       String?
  archived   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  logs HabitLog[]

  @@index([userId, archived])
}

model HabitLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  // +1 for POSITIVE check (reward), -1 for NEGATIVE check (penalty).
  // Direction is on Habit; we keep the log signed so we can sum
  // today's contributions cleanly.
  delta     Int
  goldDelta Int      @default(0)
  xpDelta   Int      @default(0)
  loggedAt  DateTime @default(now())

  @@index([userId, loggedAt])
  @@index([habitId, loggedAt])
}

// ---------------------------------------------------------------------------
// Inventory — equipment catalog + per-user ownership.
// ---------------------------------------------------------------------------

// 8 equip slots covering the standard RPG layout.
enum EquipSlot {
  HEAD // helmet, hood, hat
  BODY // armor / shirt
  HANDS // gloves
  FEET // boots
  MAIN // main-hand weapon
  OFF // off-hand shield
  NECK // amulet
  RING // ring / trinket
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum ItemSource {
  MONSTER_DROP
  BOSS_DROP
  PORTAL_LEAK
  QUEST_REWARD
  SHOP
  CRAFTED
  ACHIEVEMENT
  STARTER_KIT
}

// Static catalog of items that can exist. Seeded at migration time
// so equip/unequip and drops can reference valid itemDefIds.
model ItemDef {
  id               String     @id // slug, e.g. "warrior_sword_t2"
  name             String
  description      String?
  slot             EquipSlot
  /// Path under /public/sprites/ (e.g. "gear/weapon/weapon_warrior_2").
  sprite           String
  /// Display tint (class color, neon glow, etc.) for the slot pill.
  color            String     @default("#a8a8b8")
  rarity           ItemRarity @default(COMMON)
  /// Stat roll as a JSON object. Free-form so we can add new stats
  /// without migrations. Recognized keys:
  ///   +DMG    : additive raid damage (number)
  ///   +CRIT   : bonus crit chance % (0-1)
  ///   +EVA    : bonus evade chance % (0-1)
  ///   +DEF    : bonus defense rating
  ///   +HP     : bonus max HP
  ///   +HEAL   : bonus healing factor
  ///   +BURST  : bonus burst damage %
  ///   +DISC   : bonus discovery chance
  ///   +XP     : bonus XP gain %
  ///   +GOLD   : bonus gold find %
  stats            Json       @default("{}")
  /// Optional class lock. Null = any class can equip.
  classRestriction ClassName?
  /// Optional set id (e.g. "iron_pact"). Wearing N pieces of the same
  /// set grants a bonus applied at equip time. (Reserved for Phase E.)
  setId            String?
  createdAt        DateTime   @default(now())

  ownedBy InventoryItem[]

  @@index([slot])
  @@index([rarity])
  @@index([classRestriction])
}

// A user's copy of an ItemDef. One InventoryItem per owned instance;
// equipping is just setting `equippedSlot` (mutually exclusive per slot).
model InventoryItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemDefId    String
  itemDef      ItemDef    @relation(fields: [itemDefId], references: [id])
  equippedSlot EquipSlot?
  acquiredAt   DateTime   @default(now())
  source       ItemSource @default(MONSTER_DROP)
  /// Free-form notes (e.g. "Dropped by Procrastinatrix 2026-06-20").
  notes        String?

  @@unique([userId, itemDefId, acquiredAt])
  @@index([userId])
  @@index([userId, equippedSlot])
}

/// LLM provider config (single row). Lets the admin point the
/// app at OpenAI, Anthropic, or a local Ollama instance. Future
/// in-app coach/quest-narrator features read this.
///
/// Primary + Secondary: the secondary model is tried when the
/// primary fails (5xx, timeout, network error, model-not-found).
/// Either side can be unset (e.g. Ollama-only: leave primary
/// blank, set secondary). callLlm() in api/src/lib/llm.ts handles
/// the fallback chain transparently.
model LlmConfig {
  id               String   @id @default(cuid())
  // ---- Primary ----
  provider         String   @default("OPENAI") // "OPENAI" | "ANTHROPIC" | "OLLAMA" | "MINIMAX"
  apiKey           String?
  baseUrl          String?
  model            String   @default("gpt-4o-mini")
  enabled          Boolean  @default(false)
  // ---- Secondary / fallback ----
  fallbackEnabled  Boolean  @default(false)
  fallbackProvider String? // "OPENAI" | "ANTHROPIC" | "OLLAMA" | "MINIMAX"
  fallbackApiKey   String?
  fallbackBaseUrl  String?
  fallbackModel    String?
  // ---- Per-task overrides ----
  // Each entry replaces the primary for one task. Use case: route
  // food Ask-AI to a JSON-reliable local model (gemma3:12b) while
  // the spiritual director runs on a warmer persona model
  // (dolphin3:8b). Missing entries fall back to the default
  // primary + fallback chain. The apiKey/baseUrl are optional per
  // task — if absent, we reuse the primary's. This keeps a local-
  // only Ollama setup clean (one key, one baseUrl, many models).
  taskOverrides    Json? // { food?, foodSaved?, morningReport?, spiritualDirector? }
  // ---- Shared ----
  systemPrompt     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// LLM-generated morning report. One row per (user, date) — the
/// date is the user's "today" in their IANA timezone. The
/// /dashboard "morning report" card shows today's row if it exists
/// and is < 7 days old. Per-metric blocks on the dashboard
/// (sleep, training, recovery, etc.) show their own insight
/// sentence from this same row.
model MorningReport {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// YYYY-MM-DD in the user's timezone. Combined with userId for
  /// uniqueness so re-generating on the same day overwrites.
  date                 String
  /// Cross-domain advice (2-3 sentences) shown in the top dashboard
  /// card. Written for the user, not clinical.
  general              String?
  /// Per-metric insights. Each ≤ 2 sentences. Empty string if no
  /// notable signal (the metric was steady / untracked).
  sleep                String?
  training             String?
  recovery             String?
  nutrition            String?
  spiritual            String?
  /// JSON array of risk-flag strings surfaced as amber toasts.
  /// E.g. "HRV below 30d baseline 3 of last 5 days".
  riskFlags            String?
  /// Hardcore-mode penalty ledger. JSON array of
  /// {label, severity: 'warn'|'scold', note}. Empty string when the
  /// user is in Casual mode OR has nothing to flag. Surfaced as a
  /// dedicated "Penalties" section on the dashboard card.
  penalties            String?
  /// Plateau detector output. JSON array of
  /// {kind, exercise?, since, note} (e.g. NO_PR_RECENT,
  /// ONE_RM_REGRESSION, VOLUME_REGRESSION, WEIGHT_FLATLINE).
  /// Empty array when nothing's stale. Surfaced as a "Stale" section.
  plateaus             String?
  /// Deterministic macro/timing nudges (caffeine pre-workout, alcohol
  /// vs HRV, creatine consistency, hydration, sleep-overlap). JSON
  /// array of {label, severity: 'warn'|'tip', note}. Surfaced as
  /// "Macro nudges" section.
  nudges               String?
  /// Mirror of nudges but for positive callouts (creatine on schedule,
  /// caffeine-free evenings, etc.). Same shape. "Good calls" section.
  positiveNudges       String?
  /// Implausible set values from workouts in the last 24h that the
  /// per-exercise plausibility detector flagged (Bench 500kg, Squat
  /// 1000 reps, etc.). JSON array of
  /// {workoutId, workoutName, exercise, setIndex, value, unit,
  /// reason, severity}. Surfaced as "Implausible sets" section so
  /// the user can fix typos that pollute the LLM narrative.
  impossibleValueFlags String?
  /// Model that generated the report (for audit + forcing regen
  /// when the LLM provider changes).
  model                String?
  /// Latency in ms (for performance monitoring + a "this took 4s"
  /// breadcrumb in dev).
  latencyMs            Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

/// Cached USCCB daily Mass readings. One row per liturgical date
/// (YYYY-MM-DD). Populated on first request via the fetcher; once
/// cached, the spiritual director feature works fully offline.
///
/// Schema mirrors the USCCB daily readings JSON shape:
///   - firstReading:  OT / NT pre-Gospel
///   - responsorialPsalm:  psalm with refrain
///   - gospelAcclamation:  Alleluia verse
///   - gospel:  the Gospel passage
///   - liturgicalInfo:  feast / memorial / weekday / season
///
/// We do NOT cache the user's LLM reflection here — that's stored
/// in SpiritualReflection keyed on (userId, date) so different
/// users get their own voice on the same Gospel.
model UsccbDailyReading {
  id                String   @id @default(cuid())
  /// YYYY-MM-DD in liturgical calendar (USCCB's calendar is what
  /// the source uses, not the user's local timezone).
  date              String   @unique
  /// Human-readable label: "Friday of the 11th Week in Ordinary Time"
  /// or "Memorial of St. Thomas the Apostle".
  liturgicalInfo    String?
  firstReading      String?
  firstReadingRef   String?
  responsorialPsalm String?
  psalmRef          String?
  gospelAcclamation String?
  gospel            String?
  gospelRef         String?
  /// Where this came from: 'usccb' (canonical) or 'manual' (admins
  /// can paste a reading for a date the USCCB site didn't have).
  source            String   @default("usccb")
  /// Hash of the canonical URL so we can detect USCCB site changes
  /// and re-fetch.
  sourceHash        String?
  fetchedAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Per-user LLM reflection on the day's USCCB Gospel. Same shape
/// as MorningReport (keyed on user + date) so it integrates with
/// the existing cache pattern.
model SpiritualReflection {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// YYYY-MM-DD in the user's timezone.
  date             String
  /// The Gospel that was the source for the reflection (cached
  /// here too so the UI can show the passage alongside the
  /// reflection without re-querying the readings table).
  gospelRef        String?
  gospelText       String?
  liturgicalInfo   String?
  /// 2-3 sentence reflection from the LLM spiritual director.
  reflection       String
  /// Optional: name of a patron saint the LLM suggests for the
  /// day (e.g. by name-day or by current struggle). Empty if none.
  patronSuggestion String?
  model            String?
  latencyMs        Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

/// One rolling conversation per user with the AI coach. Auto-spawned
/// on first /coach POST (no "New conversation" button yet — that's
/// P3 multi-conversation scope). userId @unique enforces the
/// "one chat per user" rule; DELETE /coach/messages clears it
/// (and resets summary/summaryUpTo).
model CoachConversation {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// LLM-compressed summary of compacted messages — null until the
  /// first time messageCount crosses 30. Prepended to the prompt as
  /// "summary of earlier conversation" before the sliding window.
  /// Stored as plain text (no JSON shape) so it's directly usable
  /// as a system-prompt block on the next LLM call.
  summary       String?
  /// The createdAt timestamp of the most recent message included
  /// in the summary. Lets us re-summarize incrementally in future
  /// iterations (today: single-shot at threshold). Nullable for
  /// the same reason as `summary`.
  summaryUpTo   DateTime?
  /// Cheap count — maintained on every append so the route can
  /// decide whether to trigger compaction without a COUNT(*).
  messageCount  Int      @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  messages      CoachMessage[]
}

/// One turn in the AI Coach conversation. Role = 'user' |
/// 'assistant' | 'system'. The 'system' role is reserved for
/// future compaction-injected messages (v1.1 always uses the
/// summary field on CoachConversation instead — same effect, fewer
/// rows).
///
/// Model + latency are captured per assistant message so the UI
/// can surface "(minimax-m3 · 1.2s)" and so we can build a
/// per-user cost/usage dashboard later.
model CoachMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // 'user' | 'assistant' | 'system'
  content        String
  model          String?
  latencyMs      Int?
  /// Best-effort token estimates (chars / 4). Used for the
  /// per-user daily cost cap (future) and the LLM-call display.
  /// Optional so older rows pre-this-feature don't break the
  /// SELECT.
  tokensIn       Int?
  tokensOut      Int?
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

/// Category of a user-tracked item. Drives which panel shows it
/// (Supplements / Probiotics / etc.) and which default unit makes
/// sense (mg for vitamins, CFU for probiotics).
enum TrackedItemCategory {
  VITAMIN
  MINERAL
  FATTY_ACID
  PROBIOTIC
  HERB
  AMINO_ACID
  OTHER
}

/// Unit for a user-tracked item's default dose. Stored as a free
/// string so the UI can also accept uncommon units (drops, scoops,
/// capsules). The common ones are typed below.
enum TrackedItemUnit {
  mg
  g
  mcg
  iu
  cfu
  capsule
  drop
  scoop
  pill
}

/// Substance categories for one-shot event logging (not daily
/// check-offs). Each form has a different recovery/sleep/lung
/// impact — captured in the LLM-facing notes, not in code.
enum SubstanceCategory {
  NICOTINE
  CAFFEINE
  ALCOHOL
  ELECTROLYTE
}

/// User's persistent catalog of items they want to track (e.g. "I
/// take Vitamin D3 2000 IU every day"). Distinct from the historical
/// `SupplementLog` table which records the actual dose taken; the
/// tracker holds the *intent* (the items you want in your daily
/// checklist) and `DailyTrackedItem` records today's check-off.
///
/// No defaults: this table is empty when the user starts. Items are
/// added when the user first logs them or via the "Add item" button.
model UserTrackedItem {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Display name. Free-form (e.g. "Magnesium Glycinate", "Culturelle",
  /// "Athletic Greens"). Not unique on its own — same name can have
  /// different categories (the @@unique handles that).
  name        String
  category    TrackedItemCategory
  /// Default dose. The "tap to check off" action uses this value
  /// unless the user overrides per-check. Amounts usually don't vary
  /// day to day, which is the whole point of the tracker.
  defaultDose Float
  doseUnit    TrackedItemUnit
  /// Free-form notes (e.g. "with breakfast", "before bed").
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  dailyLogs   DailyTrackedItem[]

  @@unique([userId, name, category])
  @@index([userId, category])
}

/// Daily check-off for a tracked item. One row per (user, item, date).
/// Tapping the chip inserts/upserts; tapping again deletes (uncheck).
/// Resets naturally each calendar day because the date key changes.
model DailyTrackedItem {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      UserTrackedItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  /// YYYY-MM-DD in the user's timezone.
  date      String
  /// Snapshot of the dose at the time of check-off (so historical
  /// "I took 2000 IU on 2026-06-21" survives even if the user later
  /// changes the defaultDose to 5000 IU).
  dose      Float
  doseUnit  TrackedItemUnit
  createdAt DateTime        @default(now())

  @@unique([userId, itemId, date])
  @@index([userId, date])
  @@index([itemId, date])
}

/// One-shot event log for substances (nicotine / caffeine / alcohol /
/// electrolytes). NOT a daily checklist — each row is a single
/// consumption event. The form field captures the specific delivery
/// (cigarette, vape, zyn, hookah, etc.) which has different recovery
/// impact than a generic "nicotine" entry.
model SubstanceLog {
  id       String            @id @default(cuid())
  userId   String
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category SubstanceCategory
  /// Specific delivery form. Free-form string keyed by category:
  ///   NICOTINE:  cigarette, vape, zyn, hookah, cigar, chew
  ///   CAFFEINE:  coffee, tea, energy_drink, pre_workout, soda
  ///   ALCOHOL:   beer, wine, spirits, seltzer, cider
  ///   ELECTROLYTE: lmnt, salt_capsule, liquid_iv, coconut_water
  form     String
  /// Optional quantity (drinks, mg, pouches, scoops). Free-form
  /// unit so the UI can pick the right input per form.
  amount   Float?
  unit     String?
  /// Free-form context. "pre-workout 1h before lift", "with dinner",
  /// "social, 3 over the evening" — fuels the morning report's
  /// correlation engine.
  context  String?
  loggedAt DateTime          @default(now())

  @@index([userId, loggedAt])
  @@index([userId, category, loggedAt])
}

/// Meal section in the food tracker.
enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum FoodSource {
  OPENFOODFACTS
  USDA
  MANUAL
}

model FoodItem {
  id           String      @id @default(cuid())
  source       FoodSource
  sourceId     String
  name         String
  brand        String?
  imageUrl     String?
  servingSizeG Float?
  calories     Float
  proteinG     Float
  carbG        Float
  fatG         Float
  fiberG       Float?
  sugarG       Float?
  sodiumMg     Float?
  sourceUrl    String?
  fetchedAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  mealEntries  MealEntry[]

  @@unique([source, sourceId])
  @@index([name])
}

model MealEntry {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId   String
  food     FoodItem @relation(fields: [foodId], references: [id], onDelete: Cascade)
  meal     MealType
  servings Float
  note     String?
  loggedAt DateTime @default(now())

  @@index([userId, loggedAt])
  @@index([userId, meal, loggedAt])
}

/// User's own saved foods. The "daily shake" use case: a recipe
/// the user eats every day with stable macros. Stored separately
/// from FoodItem (which is a third-party cache: OFF + USDA rows
/// keyed by (source, sourceId)) so the user's edits don't pollute
/// the shared cache. When the user logs a SavedFood, we copy the
/// macros into a FoodItem (source = MANUAL) on the fly and link
/// the MealEntry to it — the MealEntry path stays the same.
model SavedFood {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  brand        String?
  /// Per-serving macros. Servings in the UI = 1 by default; the
  /// meal entry stores servings * these numbers.
  servingSizeG Float?
  calories     Float
  proteinG     Float
  carbG        Float
  fatG         Float
  fiberG       Float?
  sugarG       Float?
  sodiumMg     Float?
  /// Free-form note ("whey + banana + oat milk", "Lentils, 1 cup dry")
  recipe       String?
  /// For sorting the "recent" list. Decremented on each quick-log
  /// so the user's most-eaten items bubble to the top without
  /// needing a separate join table.
  useCount     Int      @default(0)
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId, lastUsedAt])
}

// ============================================================
// GeoCache — Nominatim (OpenStreetMap) reverse-geocode results,
// keyed by a rounded lat/lng grid (~110m at 3 decimals). Avoids
// hammering the public Nominatim endpoint (1 req/sec policy)
// when users bulk-import FIT files. The lat/lng are also stored
// so we can re-query with a finer zoom if we ever need to.
// ============================================================

model GeoCache {
  /// Key = `${round3(lat)}_${round3(lng)}` — collision is fine,
  /// two points 110m apart often have the same place name.
  key         String   @id
  lat         Float
  lng         Float
  /// Short label ("Kennesaw"). Used for activity titles like
  /// "Kennesaw Running".
  shortName   String
  /// Long display name ("Kennesaw, Cobb County, Georgia, US").
  displayName String
  zoom        Int      @default(10)
  fetchedAt   DateTime @default(now())
}

// ============================================================
// WeatherCache — Open-Meteo current + daily forecast responses,
// keyed by a rounded lat/lng grid (~110m at 3 decimals). Same
// caching strategy as GeoCache: the upstream is free but rate-
// limited, and a single user hot-reloading the page shouldn't
// trigger an outbound call every time. Default TTL handled at
// the call site (1 hour — Open-Meteo's update cadence).
// ============================================================

model WeatherCache {
  /// Key = `${round3(lat)}_${round3(lng)}` — same shape as
  /// GeoCache so callers can reuse `round3` + `keyOf` helpers.
  key       String   @id
  lat       Float
  lng       Float
  /// Full Open-Meteo response payload (current + daily fields
  /// we care about). Stored as JSON so we can extend the
  /// fetched fields without a migration.
  payload   Json
  fetchedAt DateTime @default(now())
}

// ============================================================
// CorrelationSnapshot — nightly Pearson-r snapshot per (user,
// habit, outcome, lag). Drives the trend sparklines on /insights
// so the user can answer "is my sleep→PR correlation getting
// stronger or weaker over the past 12 weeks?"
//
// One row per (userId, snapshotDate, habit, outcome, lag). We
// delete+rewrite the snapshotDate's rows when re-running so a
// failed cron doesn't leave stale rows around.
// ============================================================

model CorrelationSnapshot {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotDate DateTime // YYYY-MM-DD 00:00 UTC of the snapshot run
  /// Rolling window length in days (e.g. 30, 60, 90).
  lookbackDays Int
  /// "SLEEP_HOURS", "HRV", "PROTEIN_G", etc. — or synthetic
  /// habit codes like "WORKOUT_FREQUENCY_7D" that are computed
  /// inside the correlation engine rather than read directly
  /// from Measurement.
  habit        String
  /// "WORKOUT_VOLUME", "PR_COUNT", "WEIGHT_TREND_7D", etc.
  outcome      String
  /// Days the habit leads the outcome. 0 = same day; 1 = habit
  /// yesterday predicts outcome today.
  lagDays      Int      @default(0)
  /// Pearson r in [-1, +1], rounded to 2dp before storage.
  r            Float
  /// Number of paired data points used.
  n            Int

  @@unique([userId, snapshotDate, habit, outcome, lagDays, lookbackDays])
  @@index([userId, habit, outcome, snapshotDate])
}

// ============================================================
// TrustedDevice — "remember this device for 90 days" feature.
// On successful TOTP login, the user can opt to issue a long-
// lived HttpOnly cookie bound to a TrustedDevice row. On
// subsequent logins, if the cookie's hashed token matches a
// non-expired row, the TOTP step is skipped.
//
// The token in the cookie is opaque + random; the row stores
// only its sha256 hash so a DB leak doesn't let an attacker
// forge a "trusted" cookie.
// ============================================================

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(opaque-token). 32 hex chars.
  tokenHash  String   @unique
  /// User-supplied label like "MacBook Pro" or "iPhone 15". Falls
  /// back to the User-Agent prefix if the client doesn't supply one.
  label      String
  /// Last User-Agent that used this token. Surfaces in the
  /// trusted-devices list so the user can recognize which row
  /// to revoke if something looks off.
  userAgent  String?
  /// Last IP. Same purpose as userAgent — surfaces in the list.
  lastIp     String?
  /// Last time this token was used to skip TOTP. Used to prune
  /// stale rows (e.g. > 90 days since last use → drop).
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
}

// ============================================================
// RecoveryCode — single-use backup codes for users who lose
// access to their authenticator app. Generated at 2FA setup
// time; the user is told to write them down once. Stored as
// sha256 hashes so a DB read doesn't leak the codes.
// ============================================================

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// sha256(normalized code). The row is deleted on use, so a
  /// given hash only exists once in the table.
  codeHash  String
  /// null = unused. Set when the user burns this code in place
  /// of a TOTP code at login.
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, codeHash])
  @@index([userId])
}

/// Per-metric AI deep-dive. One row per (user, metric) tuple,
/// regenerated on demand or when the cache TTL expires. Powers the
/// `/insights/metrics` page where every tracked measurement gets a
/// short narrative ("your HRV averaged 51ms, down 4 vs the prior
/// 30d — typically a sign of accumulated training stress").
///
/// `factors` is a JSON array of {label, signal, weight, note} so
/// the UI can render structured chips alongside the prose summary.
model MetricInsight {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric        MetricType
  /// 2-3 sentence summary, written for the user.
  summary       String
  /// JSON array of {label, signal, weight, note} factors. Max 6.
  factors       String
  /// Model that generated the insight (audit + force-regen on
  /// model swap).
  model         String?
  /// Latency in ms (informational).
  latencyMs     Int?
  /// Schema/prompt version. Bump to invalidate cached insights.
  promptVersion Int        @default(1)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([userId, metric])
  @@index([userId])
}

/// Per-activity AI analysis. One row per workout, generated on
/// demand from the activity detail page. The LLM is given the
/// workout's exercises + sets + RPE + the user's recent HRV/sleep/
/// soreness/mood context and asked to score training quality,
/// flag risk factors, and recommend recovery load for the next
/// 24-48h.
///
/// Caching: the first POST creates a row; subsequent reads return
/// the cached insight. Force-regenerate via POST with ?force=1
/// (used by the "Regenerate" button — picks up new context the
/// user logged after the first generation).
///
/// `factors` is a JSON array of {label, signal, weight, note} so
/// the UI can render structured chips. `promptVersion` lets us
/// invalidate cache if the prompt changes in a way that matters.
model ActivityInsight {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutId     String   @unique
  /// 2-4 sentence overall summary of how this session landed.
  summary       String
  /// Training quality score 1-10. Computed from RPE + volume vs
  /// recent baseline + HRV/sleep context.
  qualityScore  Int
  /// light | normal | rest. Drives the "next session should be…"
  /// recommendation.
  recoveryLoad  String
  /// low | medium | high. Reflects how much context was available
  /// to score this — no HRV data = low; HRV + sleep + RPE + 14d
  /// baseline = high.
  confidence    String
  /// JSON: [{label, signal: 'positive'|'negative'|'neutral', weight: 0..1, note}]
  /// Renders as a "key factors" list in the UI. Max 6 entries.
  factors       String
  /// LLM model identifier (for audit + regen-when-model-changes).
  model         String?
  /// Latency in ms.
  latencyMs     Int?
  /// Schema/prompt version. Bump when the prompt changes in a way
  /// that should invalidate existing cached insights.
  promptVersion Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// =============================================================
// Pet system (added 2026-07-04).
//
// Three new models: PetBreed (the catalog), PetInstance (one
// per user), PetFeedLog (audit trail for gold-spent feed events).
// All combat-derived state — HP per battle, current sprite stage,
// armoured toggle — is computed from these rows plus workout XP
// (10% auto-routed to the pet during the workout commit hook).
//
// A pet never dies; fainting just sets `faintedAt` and the user
// pays the vet (10 + 5*level gold) to clear it. See HANDOFF.md
// in the fitquest-sprites repo for the full design.
// =============================================================

/// Catalog of pet breeds. Each breed has its own sprite base
/// path, color variants list, and per-breed base HP / Attack.
/// Stock rotation is driven by `availableFrom`/`availableTo`;
/// null = always in stock (the starter).
model PetBreed {
  id             String        @id @default(cuid())
  /// Stable string key matching the sprite filename prefix.
  /// e.g. "german-shepherd" → `german-shepherd-puppy.png`.
  /// Don't change without a migration — sprite files reference it.
  slug           String        @unique
  displayName    String // "German Shepherd"
  /// Coarse taxonomy: "dog", "cat", "amphibian", "bird", ...
  species        String
  costGold       Int // 200 for v1
  isStarter      Boolean       @default(false)
  /// JSON array of variant names keyed to file suffixes.
  /// e.g. `["black-tan","white","liver"]` → files like
  /// `german-shepherd-puppy-black-tan.png`. The first entry is
  /// the default variant for new purchases.
  colorVariants  String
  /// Stock rotation window. Null = always in stock (the starter).
  /// Otherwise the breed is in shop stock only between these dates.
  availableFrom  DateTime?
  availableTo    DateTime?
  description    String
  baseHp         Int           @default(50)
  baseAttack     Int           @default(2)
  /// File path within `web/public/sprites/pets/` minus extension
  /// and variant suffix. Stages are `<spriteBasePath>-<stage>.png`
  /// for the default variant, `<spriteBasePath>-<stage>-<variant>.png`
  /// for specific variants.
  spriteBasePath String
  /// JSON array of stage names this breed supports, in order:
  /// `["puppy","adult","adultArmored","injuredArmored"]`.
  spriteStages   String
  createdAt      DateTime      @default(now())
  pets           PetInstance[]
}

/// One row per user, adopted pet. Combat-derived state goes on
/// this row. The HP shown in the UI at any moment is computed as
/// min(current hp from the last event, baseHp); `hpAfterCombat`
/// is the persisted HP from the most recent combat event (-1 =
/// never been in combat, full HP implied).
model PetInstance {
  id            String       @id @default(cuid())
  /// No @unique: users can own multiple pets (up to MAX_PETS_PER_USER
  /// enforced at the API level — see api/src/lib/petStats.ts). The
  /// "primary" pet (the one shown by default on /pet) is the
  /// oldest by createdAt.
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  breedId       String
  breed         PetBreed     @relation(fields: [breedId], references: [id])
  /// Owner-named. Free-text input on /shop, 1-24 chars.
  name          String
  /// Selected at purchase time, must be one of PetBreed.colorVariants.
  colorVariant  String
  level         Int          @default(1)
  xp            Int          @default(0)
  /// Persisted HP after the most recent combat event. -1 means
  /// never been in combat (show full bar). Resets to baseHp on vet.
  hpAfterCombat Int      @default(-1)
  /// User-chosen "primary" pet — the one shown in the /shop's
  /// "Your companion" panel and on the /pet page roster's primary
  /// slot. Defaults to false; the user can set it via
  /// POST /pet/set-primary. If the user has multiple pets and
  /// none of them is marked primary, the GET /pet endpoint falls
  /// back to the oldest (createdAt asc).
  isPrimary     Boolean   @default(false)
  /// Whether the user has deployed this pet into active combat.
  /// When true AND pet.level >= 15 AND !faintedAt, the combat
  /// endpoints grant pet XP and HP loss. Defaults to false —
  /// user must opt in even at Lv15+. When pet faints mid-fight,
  /// this flips to false immediately.
  deployed      Boolean   @default(false)
  /// At the moment the pet fainted mid-encounter, this captures
  /// the boss's HP fraction lost (0.0 to 1.0). On the eventual
  /// boss kill, the pet is granted posthumous XP = lastFaintProgress
  /// × fullXpReward. Cleared after the posthumous award fires, or
  /// on next deploy toggle, or on vet revive.
  lastFaintProgress Float?
  /// Set when HP first drops to 0 in combat. Cleared by /pet/vet.
  /// While non-null, the pet contributes 0 attack and is not
  /// usable in combat until revived.
  faintedAt     DateTime?
  /// Set the first time the pet crosses level 5 (auto-evolve).
  /// Sprite resolves to "adult" once this is set.
  evolvedAt     DateTime?
  /// Set when the user toggles armor on (allowed at Lv15+).
  /// Sprite resolves to "adultArmored" while set; otherwise "adult".
  armoredAt     DateTime?
  /// Set when a Breach/Quest/Raid combat loss triggers the pet's
  /// injury. Cleared by /pet/vet. Sprite resolves to
  /// "injuredArmored" while set.
  injuredAt     DateTime?
  /// Timestamp of the most recent /pet/feed call. Used by the
  /// 1-hour cooldown check.
  lastFedAt     DateTime?
  createdAt     DateTime     @default(now())
  feedLogs      PetFeedLog[]

  @@index([breedId])
  @@index([userId])
}

/// Audit row for every successful /pet/feed call. Tracks gold
/// spent, XP granted, and when — useful for analytics and for
/// computing lifetime pet spend if we ever need that.
model PetFeedLog {
  id           String      @id @default(cuid())
  petId        String
  pet          PetInstance @relation(fields: [petId], references: [id], onDelete: Cascade)
  fedAt        DateTime    @default(now())
  /// 10 per call in v1 (matches the shop cost). Recorded for
  /// analytics, not enforced here — the API enforces it.
  foodGoldCost Int
  /// 1 per call in v1 (matches "+1 XP per feed"). Recorded for
  /// analytics, not enforced here — the API increments pet.xp.
  xpGained     Int

  @@index([petId])
}
