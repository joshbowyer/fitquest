# Leave unset to use the Vite dev proxy (/api/* → localhost:3001).
# In production (Docker + nginx), the nginx config proxies /api/* to the
# API container, so this should also be unset.
# Set only if you want the browser to hit the API directly (e.g. over
# a different origin without a proxy).
# VITE_API_URL=http://localhost:3001
