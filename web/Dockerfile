FROM node:22-alpine AS base
WORKDIR /app

# Build context is the workspace root (.). The web/ subdirectory
# holds the vite app; the shared root lockfile comes via npm
# workspaces.

FROM base AS deps
COPY package.json package-lock.json* ./
COPY web/package.json ./web/package.json
RUN npm ci --workspaces --include-workspace-root

FROM base AS build
COPY --from=deps /app/node_modules ./node_modules
# web/package.json is needed at runtime by `npm --prefix web
# run build` (npm reads the script from there). The deps stage
# only kept node_modules.
COPY web/package.json ./web/package.json
# Only the files Vite actually needs. tsconfig.app/node are
# generated by create-vite and referenced from tsconfig.json.
COPY web/tsconfig.json ./web/tsconfig.json
COPY web/tsconfig.app.json ./web/tsconfig.app.json
COPY web/tsconfig.node.json ./web/tsconfig.node.json
COPY web/vite.config.ts ./web/vite.config.ts
COPY web/index.html ./web/index.html
COPY web/src ./web/src
COPY web/public ./web/public
COPY web/nginx.conf ./web/nginx.conf
# Use --prefix so npm runs the build script from web/package.json
# directly, instead of walking up and finding the root's build
# script (which references workspace names that don't match —
# web's package name is "fitquest-web" not "web").
RUN npm --prefix web run build

FROM nginx:1.27-alpine AS runner
COPY --from=build /app/web/dist /usr/share/nginx/html
COPY --from=build /app/web/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]